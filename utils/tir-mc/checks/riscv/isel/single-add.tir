// RUN: tir-mc --march=riscv64 --run=isel %s | filecheck %s

// The smallest interesting function: a single add. `addi` (a builtin integer
// add) selects to a RISC-V word add.

module {
  func @add(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK: riscv.addw {rd = %virt2:GPR, rs1 = %virt0:GPR, rs2 = %virt1:GPR}
