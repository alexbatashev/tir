//! Narrow and displacement-based memory operations plus stack push/pop instructions.

// Memory-access extensions: sub-64-bit loads/stores (lb/lh/lw parity through
// movzx/movsx and narrow mov), a disp32 addressing form for the 64-bit mov,
// and the stack push/pop pair. Like the base mov load/store, addressing is
// register-direct: the rsp/rbp (and r12/r13) ModR/M escapes are not modeled.

// ModR/M-escape variants. Declared before the generic memory forms so the
// assembler tries the narrow-base `_sib`/`_rbp` candidates first (they parse a
// base only in the rsp/r12 or rbp/r13 class and fall through otherwise).
// Post-RA `canonicalize_encodings` selects them for codegen; behavior-free
// (canonicalize-only), so they root no isel rules. `_sib` adds the escape SIB
// byte 0x24 (scale=00, index=none, base=100); `_rbp` uses mod=01 with a zero
// disp8.

template ExtendLoadSib for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR,
        base: GPRsib,
    }

    encoding {
        rex!({ base[3] }, { dst[3] }, 0b1)
        8..15 => 0x0F,
        16..23 => OPCODE,
        24..26 => 0b100,
        27..29 => dst[0..2],
        30..31 => 0b00,
        32..39 => 0x24,
    }

    asm {
        "{self.MNEMONIC} {dst}, [{base}]"
    }
}

template ExtendLoadRbp for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: GPR,
        base: GPRrbp,
    }

    encoding {
        rex!({ base[3] }, { dst[3] }, 0b1)
        8..15 => 0x0F,
        16..23 => OPCODE,
        24..26 => 0b101,
        27..29 => dst[0..2],
        30..31 => 0b01,
        32..39 => 0x00,
    }

    asm {
        "{self.MNEMONIC} {dst}, [{base}]"
    }
}

instruction Movzx8LoadSib for [X86_64] : ExtendLoadSib {
    param OPNAME: String = "movzx8_load_sib";
    param MNEMONIC: String = "movzx";
    param OPCODE: bits<8> = 0xB6;

    asm {
        "{self.MNEMONIC} {dst}, byte ptr [{base}]"
    }

    behavior { }
}

instruction Movzx8LoadRbp for [X86_64] : ExtendLoadRbp {
    param OPNAME: String = "movzx8_load_rbp";
    param MNEMONIC: String = "movzx";
    param OPCODE: bits<8> = 0xB6;

    asm {
        "{self.MNEMONIC} {dst}, byte ptr [{base}]"
    }

    behavior { }
}

