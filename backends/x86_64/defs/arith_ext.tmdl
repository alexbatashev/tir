//! Extended scalar integer arithmetic, shifts, multiplication, and widening moves.

// Scalar integer extensions beyond the base ALU set: immediate compare/test,
// group-3 unary ops, CL-count and rotate shifts, widening multiply, and the
// movzx/movsx register extensions. Division is not modeled: idiv's 128-bit
// rdx:rax dividend has no faithful representation in the semantic language.

// Group-3 unary `op r/m64`: REX.W + 0xF7 + ModR/M(mod=11, reg=EXT, rm=dst).
tmpl_runary!(RegUnary, X86_64, GPR, rexw = 0b1)

tmpl_runary!(RegUnary32, X86_64, GPR32, rexw = 0b0)

// No-REX group-3 unary templates over the low subclasses (0xF7 / 0x66+0xF7 /
// 0xF6). Selected post-RA by `canonicalize_encodings` and by the assembler's
// specificity sort where GNU as omits the empty REX.
tmpl_runary!(RegUnary32Norex, GPR32low, norex)

tmpl_runary!(RegUnary16Norex, GPR16low, prefix66norex)

tmpl_runary!(RegUnary8Norex, GPR8low, bytenorex)

// `movzx/movsx r64, r/m8`: REX.W + 0x0F + opcode, dst in ModR/M.reg, the
// narrow source in rm (the `RegRegExt` field layout with a narrow source).
tmpl_extend!(ExtendReg8, GPR8)

tmpl_extend!(ExtendReg16, GPR16)

// Immediate flag definers: the group-1 /digit layout of `RegImm`, writing
// EFLAGS only.

instruction CmpImm for [X86_64] : RegImm {
    param OPNAME: String = "cmp_imm";
    param MNEMONIC: String = "cmp";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b111;

    behavior {
        sub_flags!({ sext(imm, self.XLEN) }, { self.XLEN - 1 })
    }
}

instruction TestImm for [X86_64] : RegImm {
    param OPNAME: String = "test_imm";
    param MNEMONIC: String = "test";
    param OPCODE: bits<8> = 0xF7;
    param EXT: bits<3> = 0b000;

    behavior {
        test_flags!({ sext(imm, self.XLEN) }, { self.XLEN }, { self.XLEN - 1 })
    }
}

instruction SubImm for [X86_64] : RegImm {
    param OPNAME: String = "sub_imm";
    param MNEMONIC: String = "sub";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b101;

    behavior {
        dst = dst - sext(imm, self.XLEN);
    }
}

instruction Neg for [X86_64] : RegUnary {
    param MNEMONIC: String = "neg";
    param EXT: bits<3> = 0b011;

    behavior {
        dst = zext(0b0, self.XLEN) - dst;
    }
}

instruction Not for [X86_64] : RegUnary {
    param MNEMONIC: String = "not";
    param EXT: bits<3> = 0b010;

    behavior {
        dst = ~dst;
    }
}

// One-operand imul (0xF7 /5): rdx:rax = rax * r/m64, the signed widening
// multiply (mulh parity; unsigned `mul`'s high half is not expressible, the
// semantic language's widening multiply is signed-only).
instruction ImulWide for [X86_64] : RegUnary {
    param OPNAME: String = "imul_wide";
    param MNEMONIC: String = "imul";
    param EXT: bits<3> = 0b101;

    behavior {
        GPR::rdx = extract(GPR::rax * dst, (2 * self.XLEN) - 1, self.XLEN);
        GPR::rax = extract(GPR::rax * dst, self.XLEN - 1, 0);
    }
}

// Fixed-register integer division. The dividend is the implicit `rdx:rax` pair
// and the divisor is the single register operand `dst`; the quotient lands in
// rax and the remainder in rdx. The behavior is case-split on the high half so
// the definer (cqo/xor-edx) that establishes it folds the guard structurally,
// keeping only the honest single-width arm. The `#DE` trap at `dst == 0` and at
// `MIN / -1` is not modeled: the IR div/rem ops are undefined there, so the
// total SMT-LIB value is never observable.
instruction SignExtendDividend for [X86_64] {
    param OPNAME: String = "sign_extend_dividend";
    param MNEMONIC: String = "cqo";
    encoding { 0..7 => 0x48, 8..15 => 0x99, }
    asm { "{self.MNEMONIC}" }
    behavior {
        GPR::rdx = sext(extract(GPR::rax, self.XLEN - 1, self.XLEN - 1), self.XLEN);
    }
}

instruction SignedDivide for [X86_64] : RegUnary {
    param OPNAME: String = "signed_divide";
    param MNEMONIC: String = "idiv";
    param EXT: bits<3> = 0b111;

    behavior {
        if GPR::rdx == sext(extract(GPR::rax, self.XLEN - 1, self.XLEN - 1), self.XLEN) {
            GPR::rdx = GPR::rax - (GPR::rax / dst) * dst;
            GPR::rax = GPR::rax / dst;
        } else {
            GPR::rdx = extract(
                ((zext(GPR::rdx, 2 * self.XLEN) << self.XLEN) | zext(GPR::rax, 2 * self.XLEN))
                    - (((zext(GPR::rdx, 2 * self.XLEN) << self.XLEN) | zext(GPR::rax, 2 * self.XLEN))
                        / sext(dst, 2 * self.XLEN))
                        * sext(dst, 2 * self.XLEN),
                self.XLEN - 1, 0);
            GPR::rax = extract(
                ((zext(GPR::rdx, 2 * self.XLEN) << self.XLEN) | zext(GPR::rax, 2 * self.XLEN))
                    / sext(dst, 2 * self.XLEN),
                self.XLEN - 1, 0);
        }
    }
}

instruction ZeroExtendDividend for [X86_64] {
    param OPNAME: String = "zero_extend_dividend";
    param MNEMONIC: String = "xor";
    encoding { 0..7 => 0x31, 8..15 => 0xD2, }
    asm { "{self.MNEMONIC} edx, edx" }
    behavior {
        GPR::rdx = zext(0b0, self.XLEN);
    }
}

instruction UnsignedDivide for [X86_64] : RegUnary {
    param OPNAME: String = "unsigned_divide";
    param MNEMONIC: String = "div";
    param EXT: bits<3> = 0b110;

    behavior {
        if GPR::rdx == zext(0b0, self.XLEN) {
            GPR::rdx = GPR::rax - (GPR::rax ~/ dst) * dst;
            GPR::rax = GPR::rax ~/ dst;
        } else {
            GPR::rdx = extract(
                ((zext(GPR::rdx, 2 * self.XLEN) << self.XLEN) | zext(GPR::rax, 2 * self.XLEN))
                    - (((zext(GPR::rdx, 2 * self.XLEN) << self.XLEN) | zext(GPR::rax, 2 * self.XLEN))
                        ~/ zext(dst, 2 * self.XLEN))
                        * zext(dst, 2 * self.XLEN),
                self.XLEN - 1, 0);
            GPR::rax = extract(
                ((zext(GPR::rdx, 2 * self.XLEN) << self.XLEN) | zext(GPR::rax, 2 * self.XLEN))
                    ~/ zext(dst, 2 * self.XLEN),
                self.XLEN - 1, 0);
        }
    }
}

// 32-bit fixed-register division: dividend `edx:eax`, quotient in eax and
// remainder in edx, dividend128 replaced by a 64-bit pair. `cdq` sign-extends
// eax into edx; `xor edx, edx` zero-extends (shared idiom with the 64-bit form).
instruction SignExtendDividend32 for [X86_64] {
    param OPNAME: String = "sign_extend_dividend32";
    param MNEMONIC: String = "cdq";
    encoding { 0..7 => 0x99, }
    asm { "{self.MNEMONIC}" }
    behavior {
        GPR32::edx = sext(extract(GPR32::eax, 31, 31), 32);
    }
}

instruction SignedDivide32 for [X86_64] : RegUnary32 {
    param OPNAME: String = "signed_divide32";
    param MNEMONIC: String = "idiv";
    param EXT: bits<3> = 0b111;

    behavior {
        if GPR32::edx == sext(extract(GPR32::eax, 31, 31), 32) {
            GPR32::edx = GPR32::eax - (GPR32::eax / dst) * dst;
            GPR32::eax = GPR32::eax / dst;
        } else {
            GPR32::edx = extract(
                ((zext(GPR32::edx, 64) << 32) | zext(GPR32::eax, 64))
                    - (((zext(GPR32::edx, 64) << 32) | zext(GPR32::eax, 64))
                        / sext(dst, 64))
                        * sext(dst, 64),
                31, 0);
            GPR32::eax = extract(
                ((zext(GPR32::edx, 64) << 32) | zext(GPR32::eax, 64)) / sext(dst, 64),
                31, 0);
        }
    }
}

instruction ZeroExtendDividend32 for [X86_64] {
    param OPNAME: String = "zero_extend_dividend32";
    param MNEMONIC: String = "xor";
    encoding { 0..7 => 0x31, 8..15 => 0xD2, }
    asm { "{self.MNEMONIC} edx, edx" }
    behavior {
        GPR32::edx = zext(0b0, 32);
    }
}

instruction UnsignedDivide32 for [X86_64] : RegUnary32 {
    param OPNAME: String = "unsigned_divide32";
    param MNEMONIC: String = "div";
    param EXT: bits<3> = 0b110;

    behavior {
        if GPR32::edx == zext(0b0, 32) {
            GPR32::edx = GPR32::eax - (GPR32::eax ~/ dst) * dst;
            GPR32::eax = GPR32::eax ~/ dst;
        } else {
            GPR32::edx = extract(
                ((zext(GPR32::edx, 64) << 32) | zext(GPR32::eax, 64))
                    - (((zext(GPR32::edx, 64) << 32) | zext(GPR32::eax, 64))
                        ~/ zext(dst, 64))
                        * zext(dst, 64),
                31, 0);
            GPR32::eax = extract(
                ((zext(GPR32::edx, 64) << 32) | zext(GPR32::eax, 64)) ~/ zext(dst, 64),
                31, 0);
        }
    }
}

// Rotates share the 0xC1 shift-immediate layout. Both shifts of the rotate pair
// are computed with the count masked to the operand width, so a zero count
// degenerates to `dst | dst`.

shift_imm!(RegShift,
    (RolImm, "rol", 0b000, {
        dst = (dst << extract(imm, 5, 0))
            | (dst >> ((zext(0b0, self.XLEN) - zext(extract(imm, 5, 0), self.XLEN))
                & zext(0b111111, self.XLEN)));
    }),
    (RorImm, "ror", 0b001, {
        dst = (dst >> extract(imm, 5, 0))
            | (dst << ((zext(0b0, self.XLEN) - zext(extract(imm, 5, 0), self.XLEN))
                & zext(0b111111, self.XLEN)));
    })
)

// Register-to-register zero/sign extensions (sxtb/sxth/sxtw parity).

extend_ops!(
    (Movzx8,  "movzx8",  "movzx", ExtendReg8,  0xB6, { dst = zext(src, self.XLEN); }),
    (Movzx16, "movzx16", "movzx", ExtendReg16, 0xB7, { dst = zext(src, self.XLEN); }),
    (Movsx8,  "movsx8",  "movsx", ExtendReg8,  0xBE, { dst = sext(src, self.XLEN); }),
    (Movsx16, "movsx16", "movsx", ExtendReg16, 0xBF, { dst = sext(src, self.XLEN); })
)

// `movsxd r64, r/m32` (0x63): no 0x0F escape.
instruction Movsxd for [X86_64] {
    param MNEMONIC: String = "movsxd";

    operands {
        dst: GPR,
        src: GPR32,
    }

    encoding {
        0 => src[3],
        1 => 0b0,
        2 => dst[3],
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => 0x63,
        16..18 => src[0..2],
        19..21 => dst[0..2],
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }

    behavior {
        dst = sext(src, self.XLEN);
    }
}

// `movabs r64, imm64` (REX.W + 0xB8+rd io): the full-width constant
// materializer (lui/movz parity); the register number's low bits live in the
// opcode byte.
instruction MovAbs for [X86_64] {
    param MNEMONIC: String = "movabs";

    operands {
        dst: GPR,
        imm: bits<64>,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b1,
        4..7 => 0b0100,
        8..10 => dst[0..2],
        11..15 => 0b10111,
        16..79 => imm,
    }

    asm {
        "{self.MNEMONIC} {dst}, {imm}"
    }

    behavior {
        dst = imm;
    }
}

// 32-bit forms.

instruction Cmp32 for [X86_64] : RegReg32 {
    param OPNAME: String = "cmp32";
    param MNEMONIC: String = "cmp";
    param OPCODE: bits<8> = 0x39;

    behavior {
        sub_flags!({ src }, { 31 })
    }
}

instruction Test32 for [X86_64] : RegReg32 {
    param OPNAME: String = "test32";
    param MNEMONIC: String = "test";
    param OPCODE: bits<8> = 0x85;

    behavior {
        test_flags!({ src }, { 32 }, { 31 })
    }
}

instruction Test8 for [X86_64] : RegReg8 {
    param OPNAME: String = "test8";
    param MNEMONIC: String = "test";
    param OPCODE: bits<8> = 0x84;
    behavior { }
}

instruction CmpImm32 for [X86_64] : RegImm32 {
    param OPNAME: String = "cmp_imm32";
    param MNEMONIC: String = "cmp";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b111;

    behavior {
        sub_flags!({ sext(imm, 32) }, { 31 })
    }
}

instruction TestImm32 for [X86_64] : RegImm32 {
    param OPNAME: String = "test_imm32";
    param MNEMONIC: String = "test";
    param OPCODE: bits<8> = 0xF7;
    param EXT: bits<3> = 0b000;

    behavior {
        test_flags!({ sext(imm, 32) }, { 32 }, { 31 })
    }
}

instruction SubImm32 for [X86_64] : RegImm32 {
    param OPNAME: String = "sub_imm32";
    param MNEMONIC: String = "sub";
    param OPCODE: bits<8> = 0x81;
    param EXT: bits<3> = 0b101;

    behavior {
        dst = dst - sext(imm, 32);
    }
}

instruction Neg32 for [X86_64] : RegUnary32 {
    param OPNAME: String = "neg32";
    param MNEMONIC: String = "neg";
    param EXT: bits<3> = 0b011;

    behavior {
        dst = zext(0b0, 32) - dst;
    }
}

instruction Not32 for [X86_64] : RegUnary32 {
    param OPNAME: String = "not32";
    param MNEMONIC: String = "not";
    param EXT: bits<3> = 0b010;

    behavior {
        dst = ~dst;
    }
}

// No-REX neg/not (0xF7 /3, /2; byte 0xF6) over the low subclasses. neg = /3,
// not = /2. Behavior-free; the 32-bit forms are the canonicalize target for
// Neg32/Not32, the 16/8-bit forms are assembler-only (no narrow generic).
reg_ext_norex!(RegUnary32Norex,
    (Neg32Norex, "neg32_norex", "neg", 0b011),
    (Not32Norex, "not32_norex", "not", 0b010)
)

reg_ext_norex!(RegUnary16Norex,
    (Neg16Norex, "neg16_norex", "neg", 0b011),
    (Not16Norex, "not16_norex", "not", 0b010)
)

reg_ext_norex!(RegUnary8Norex,
    (Neg8Norex, "neg8_norex", "neg", 0b011),
    (Not8Norex, "not8_norex", "not", 0b010)
)

shift_imm!("32", "32", RegShift32,
    (RolImm, "rol", 0b000, {
        dst = (dst << extract(imm, 4, 0))
            | (dst >> ((zext(0b0, 32) - zext(extract(imm, 4, 0), 32)) & zext(0b11111, 32)));
    }),
    (RorImm, "ror", 0b001, {
        dst = (dst >> extract(imm, 4, 0))
            | (dst << ((zext(0b0, 32) - zext(extract(imm, 4, 0), 32)) & zext(0b11111, 32)));
    })
)

// No-REX 32-bit rotate-by-immediate (0xC1 /0, /1). Behavior-free; the
// canonicalize target for RolImm32/RorImm32 on a low register.
shift_imm_norex!("32", RegShift32Norex,
    (RolImm, "rol", 0b000), (RorImm, "ror", 0b001)
)
