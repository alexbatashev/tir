            dst
        };
    }
}

instruction CmovBelowEq for [X86_64] : RegRegExt {
    param MNEMONIC: String = "cmovbe";
    param OPCODE: bits<8> = 0x46;

    behavior {
        dst = if (EFLAGS::cf | EFLAGS::zf) == zext(0b1, 1) {
            src
        } else {
            dst
        };
    }
}

instruction CmovAbove for [X86_64] : RegRegExt {
    param MNEMONIC: String = "cmova";
