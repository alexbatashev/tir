// The rest of the EFLAGS consumers: the remaining jcc conditions, setcc
// (cset/slt parity) and cmovcc (csel parity). Condition guards mirror the
// jcc family in base.tmdl; only cf/zf/sf/of are modeled.

// `setcc r/m8`: REX + 0x0F + 0x90|cc + ModR/M(mod=11, reg=0, rm=dst).
template SetccReg for [X86] {
    param MNEMONIC: String;
    param CC: bits<8>;

    operands {
        dst: GPR8,
    }

    encoding {
        0 => dst[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0x0F,
        16..23 => CC,
        24..26 => dst[0..2],
        27..29 => 0b000,
        30..31 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}"
    }
}

// Remaining conditional jumps.

jcc_ops!(
    (JumpLessEq,      "jle", 0x8E, { (EFLAGS::zf | (EFLAGS::sf ^ EFLAGS::of)) == zext(0b1, 1) }),
    (JumpGreater,     "jg",  0x8F, { (EFLAGS::zf | (EFLAGS::sf ^ EFLAGS::of)) == zext(0b0, 1) }),
    (JumpBelowEq,     "jbe", 0x86, { (EFLAGS::cf | EFLAGS::zf) == zext(0b1, 1) }),
    (JumpAbove,       "ja",  0x87, { (EFLAGS::cf | EFLAGS::zf) == zext(0b0, 1) }),
    (JumpSign,        "js",  0x88, { EFLAGS::sf == zext(0b1, 1) }),
    (JumpNoSign,      "jns", 0x89, { EFLAGS::sf == zext(0b0, 1) }),
    (JumpOverflow,    "jo",  0x80, { EFLAGS::of == zext(0b1, 1) }),
    (JumpNoOverflow,  "jno", 0x81, { EFLAGS::of == zext(0b0, 1) })
)

// setcc family.

setcc_ops!(
    (SetEq,        "sete",  0x94, { EFLAGS::zf == zext(0b1, 1) }),
    (SetNotEq,     "setne", 0x95, { EFLAGS::zf == zext(0b0, 1) }),
    (SetLess,      "setl",  0x9C, { EFLAGS::sf != EFLAGS::of }),
    (SetGreaterEq, "setge", 0x9D, { EFLAGS::sf == EFLAGS::of }),
    (SetLessEq,    "setle", 0x9E, { (EFLAGS::zf | (EFLAGS::sf ^ EFLAGS::of)) == zext(0b1, 1) }),
    (SetGreater,   "setg",  0x9F, { (EFLAGS::zf | (EFLAGS::sf ^ EFLAGS::of)) == zext(0b0, 1) }),
    (SetBelow,     "setb",  0x92, { EFLAGS::cf == zext(0b1, 1) }),
    (SetAboveEq,   "setae", 0x93, { EFLAGS::cf == zext(0b0, 1) }),
    (SetBelowEq,   "setbe", 0x96, { (EFLAGS::cf | EFLAGS::zf) == zext(0b1, 1) }),
    (SetAbove,     "seta",  0x97, { (EFLAGS::cf | EFLAGS::zf) == zext(0b0, 1) })
)

// cmovcc family: `cmovcc r64, r/m64` (0x0F 0x40|cc), the `RegRegExt` layout.
// The destination is read on the not-taken path, so it stays tied.

cmovcc_ops!(
    (CmovEq,        "cmove",  0x44, { EFLAGS::zf == zext(0b1, 1) }),
    (CmovNotEq,     "cmovne", 0x45, { EFLAGS::zf == zext(0b0, 1) }),
    (CmovLess,      "cmovl",  0x4C, { EFLAGS::sf != EFLAGS::of }),
    (CmovGreaterEq, "cmovge", 0x4D, { EFLAGS::sf == EFLAGS::of }),
    (CmovLessEq,    "cmovle", 0x4E, { (EFLAGS::zf | (EFLAGS::sf ^ EFLAGS::of)) == zext(0b1, 1) }),
    (CmovGreater,   "cmovg",  0x4F, { (EFLAGS::zf | (EFLAGS::sf ^ EFLAGS::of)) == zext(0b0, 1) }),
    (CmovBelow,     "cmovb",  0x42, { EFLAGS::cf == zext(0b1, 1) }),
    (CmovAboveEq,   "cmovae", 0x43, { EFLAGS::cf == zext(0b0, 1) }),
    (CmovBelowEq,   "cmovbe", 0x46, { (EFLAGS::cf | EFLAGS::zf) == zext(0b1, 1) }),
    (CmovAbove,     "cmova",  0x47, { (EFLAGS::cf | EFLAGS::zf) == zext(0b0, 1) })
)
