)

alu_ri8!(RegImm8s16Norex, X86_64,
    (AddImm8s16Norex, "add_imm8s16_norex", "add", 0b000),
    (OrImm8s16Norex,  "or_imm8s16_norex",  "or",  0b001),
    (AndImm8s16Norex, "and_imm8s16_norex", "and", 0b100),
    (XorImm8s16Norex, "xor_imm8s16_norex", "xor", 0b110)
)

// No-REX shift-by-immediate forms (low subclasses).
shift_imm_norex!("32", RegShift32Norex,
    (ShlImm, "shl", 0b100), (ShrImm, "shr", 0b101), (SarImm, "sar", 0b111)
)

shift_imm_norex!("16", RegShift16Norex,
    (ShlImm, "shl", 0b100), (ShrImm, "shr", 0b101), (SarImm, "sar", 0b111)
)

shift_imm_norex!("8", RegShift8Norex,
    (ShlImm, "shl", 0b100), (ShrImm, "shr", 0b101), (SarImm, "sar", 0b111)
)

// No-REX by-cl shift forms (low subclasses). The 32-bit forms canonicalize
// ShlCl32/ShrCl32/SarCl32; the 16/8-bit forms are assembler-only.
reg_ext_norex!(RegShiftCl32Norex,
    (ShlCl32Norex, "shl_cl32_norex", "shl", 0b100),
    (ShrCl32Norex, "shr_cl32_norex", "shr", 0b101),
    (SarCl32Norex, "sar_cl32_norex", "sar", 0b111)
)

reg_ext_norex!(RegShiftCl16Norex,
    (ShlCl16Norex, "shl_cl16_norex", "shl", 0b100),
    (ShrCl16Norex, "shr_cl16_norex", "shr", 0b101),
    (SarCl16Norex, "sar_cl16_norex", "sar", 0b111)
)

reg_ext_norex!(RegShiftCl8Norex,
    (ShlCl8Norex, "shl_cl8_norex", "shl", 0b100),
    (ShrCl8Norex, "shr_cl8_norex", "shr", 0b101),
    (SarCl8Norex, "sar_cl8_norex", "sar", 0b111)
)

alu_ri!("8H", "8h", RegImm8H,
    (AddImm, "add_imm", "add", 0x80, 0b000, { dst = dst + sext(imm, 8); }),
    (OrImm,  "or_imm",  "or",  0x80, 0b001, { dst = dst | sext(imm, 8); }),
    (AndImm, "and_imm", "and", 0x80, 0b100, { dst = dst & sext(imm, 8); }),
    (XorImm, "xor_imm", "xor", 0x80, 0b110, { dst = dst ^ sext(imm, 8); }),
    (MovImm, "mov_imm", "mov", 0xC6, 0b000, { dst = sext(imm, 8); })
)

shift_imm!("8H", "8h", RegShift8H,
    (ShlImm, "shl", 0b100, { dst = dst << extract(imm, 4, 0); }),
    (ShrImm, "shr", 0b101, { dst = dst >> extract(imm, 4, 0); }),
    (SarImm, "sar", 0b111, { dst = dst >>> extract(imm, 4, 0); })
)
