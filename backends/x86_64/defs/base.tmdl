    param MNEMONIC: String = "or";
    param OPCODE: bits<8> = 0x80;
    param EXT: bits<3> = 0b001;

    behavior {
        dst = dst | sext(imm, 8);
    }
}

instruction AndImm8 for [X86] : RegImm8 {
    param OPNAME: String = "and_imm8";
    param MNEMONIC: String = "and";
    param OPCODE: bits<8> = 0x80;
    param EXT: bits<3> = 0b100;

    behavior {
        dst = dst & sext(imm, 8);
    }
}

instruction XorImm8 for [X86] : RegImm8 {
    param OPNAME: String = "xor_imm8";
    param MNEMONIC: String = "xor";
    param OPCODE: bits<8> = 0x80;
    param EXT: bits<3> = 0b110;

    behavior {
        dst = dst ^ sext(imm, 8);
    }
}

instruction MovImm8 for [X86] : RegImm8 {
    param OPNAME: String = "mov_imm8";
    param MNEMONIC: String = "mov";
    param OPCODE: bits<8> = 0xC6;
    param EXT: bits<3> = 0b000;

    behavior {
        dst = sext(imm, 8);
    }
}

instruction ShlImm8 for [X86] : RegShift8 {
    param OPNAME: String = "shl8";
    param MNEMONIC: String = "shl";
    param EXT: bits<3> = 0b100;

    behavior {
        dst = dst << extract(imm, 4, 0);
    }
}

instruction ShrImm8 for [X86] : RegShift8 {
    param OPNAME: String = "shr8";
    param MNEMONIC: String = "shr";
    param EXT: bits<3> = 0b101;

    behavior {
        dst = dst >> extract(imm, 4, 0);
    }
}

instruction SarImm8 for [X86] : RegShift8 {
    param OPNAME: String = "sar8";
    param MNEMONIC: String = "sar";
    param EXT: bits<3> = 0b111;

    behavior {
        dst = dst >>> extract(imm, 4, 0);
    }
}

instruction Add8H for [X86] : RegReg8H {
    param OPNAME: String = "add8h";
    param MNEMONIC: String = "add";
    param OPCODE: bits<8> = 0x00;

    behavior {
        dst = dst + src;
    }
}

