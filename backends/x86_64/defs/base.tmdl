alu_rr!("8H", "8h", RegReg8H,
    (Add, "add", 0x00, { dst = dst + src; }),
    (Sub, "sub", 0x28, { dst = dst - src; }),
    (And, "and", 0x20, { dst = dst & src; }),
    (Or,  "or",  0x08, { dst = dst | src; }),
    (Xor, "xor", 0x30, { dst = dst ^ src; }),
    (Mov, "mov", 0x88, { dst = src; })
