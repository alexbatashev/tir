// Shift count masked to 6 bits for a 64-bit operand. The cl-count forms come
// first so the immediate forms don't parse `cl` as a symbol immediate.

instruction ShlCl for [X86_64] : RegShiftCl {
    param OPNAME: String = "shl_cl";
    param MNEMONIC: String = "shl";
    param EXT: bits<3> = 0b100;

    behavior {
        dst = dst << extract(GPR::rcx, 5, 0);
    }
}

