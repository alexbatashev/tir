// Reg/reg and reg/imm forms share a mnemonic; the assembler tries forms in
// declaration order, so register forms precede the matching immediate forms.

alu_rr!(RegReg,
    (Add, "add", 0x01, { dst = dst + src; }),
    (Sub, "sub", 0x29, { dst = dst - src; }),
    (And, "and", 0x21, { dst = dst & src; }),
    (Or,  "or",  0x09, { dst = dst | src; }),
    (Xor, "xor", 0x31, { dst = dst ^ src; }),
    (Mov, "mov", 0x89, { dst = src; })
)

// Compare: subtraction driving EFLAGS only (0x39: cmp r/m64, r64). The ALU
// forms above do not model their flag writes yet — nothing reads flags between
// a compare and its jump, so only the dedicated definers set them.
instruction Cmp for [X86_64] : RegReg {
    param MNEMONIC: String = "cmp";
    param OPCODE: bits<8> = 0x39;

    behavior {
        EFLAGS::cf = if dst ~< src {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::zf = if dst == src {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::sf = extract(dst - src, self.XLEN - 1, self.XLEN - 1);
        // Signed overflow of dst - src: operands differ in sign and the
        // result's sign differs from dst's.
        EFLAGS::of = extract((dst ^ src) & (dst ^ (dst - src)), self.XLEN - 1, self.XLEN - 1);
    }
}

// Logical compare (0x85: test r/m64, r64): flags from dst & src; cf/of clear.
instruction Test for [X86_64] : RegReg {
    param MNEMONIC: String = "test";
    param OPCODE: bits<8> = 0x85;

    behavior {
        EFLAGS::cf = zext(0b0, 1);
        EFLAGS::zf = if (dst & src) == zext(0b0, self.XLEN) {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::sf = extract(dst & src, self.XLEN - 1, self.XLEN - 1);
        EFLAGS::of = zext(0b0, 1);
    }
}

// Two-operand imul (0F AF): unlike the group-1 ALU ops, ModR/M.reg carries the
// destination.

instruction Imul for [X86_64] : RegRegExt {
    param MNEMONIC: String = "imul";
    param OPCODE: bits<8> = 0xAF;

    behavior {
        dst = dst * src;
    }
}

instruction Imul32 for [X86] : RegRegExt32 {
    param OPNAME: String = "imul32";
    param MNEMONIC: String = "imul";
    param OPCODE: bits<8> = 0xAF;

    behavior {
        dst = dst * src;
    }
}

// Immediate multiply: `imul dst, src, imm` folds a constant factor. Unlike the
// group-1 immediate ops it is non-destructive (dst = src * imm), so it selects
// `muli` against a constant without first materializing the constant.
instruction ImulImm for [X86_64] : RegRegImm {
    param OPNAME: String = "imul_imm";
    param MNEMONIC: String = "imul";
    param OPCODE: bits<8> = 0x69;

    behavior {
        dst = src * sext(imm, self.XLEN);
    }
}

instruction ImulImm32 for [X86] : RegRegImm32 {
    param OPNAME: String = "imul_imm32";
    param MNEMONIC: String = "imul";
    param OPCODE: bits<8> = 0x69;

    behavior {
        dst = src * sext(imm, 32);
    }
}

// Group-1 ops share opcode 0x81 and select via the ModR/M EXT (/digit); mov
// uses 0xC7.

alu_ri!(RegImm,
    (AddImm, "add_imm", "add", 0x81, 0b000, { dst = dst + sext(imm, self.XLEN); }),
    (OrImm,  "or_imm",  "or",  0x81, 0b001, { dst = dst | sext(imm, self.XLEN); }),
    (AndImm, "and_imm", "and", 0x81, 0b100, { dst = dst & sext(imm, self.XLEN); }),
    (XorImm, "xor_imm", "xor", 0x81, 0b110, { dst = dst ^ sext(imm, self.XLEN); }),
    (MovImm, "mov_imm", "mov", 0xC7, 0b000, { dst = sext(imm, self.XLEN); })
)

// Shift count masked to 6 bits for a 64-bit operand. The cl-count forms come
// first so the immediate forms don't parse `cl` as a symbol immediate.

shift_cl!(RegShiftCl,
    (ShlCl, "shl_cl", "shl", 0b100, { dst = dst << extract(GPR::rcx, 5, 0); }),
    (ShrCl, "shr_cl", "shr", 0b101, { dst = dst >> extract(GPR::rcx, 5, 0); }),
    (SarCl, "sar_cl", "sar", 0b111, { dst = dst >>> extract(GPR::rcx, 5, 0); })
)

shift_imm!(RegShift,
    (ShlImm, "shl", 0b100, { dst = dst << extract(imm, 5, 0); }),
    (ShrImm, "shr", 0b101, { dst = dst >> extract(imm, 5, 0); }),
    (SarImm, "sar", 0b111, { dst = dst >>> extract(imm, 5, 0); })
)

// Relative control transfers: rel32 is measured from the end of the
// instruction (RIP points past it), and `PC::pc` in behaviors is the
// instruction's own address — hence the explicit instruction-length addends.

instruction Jmp for [X86_64] {
    param MNEMONIC: String = "jmp";

    operands {
        imm: bits<32>,
    }

    encoding {
        0..7 => 0xE9,
        8..39 => imm,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }

    behavior {
        PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b101, self.XLEN);
    }
}

// Conditional jumps: EFLAGS-guarded PC writes. Selection derives cmp/test +
// jcc branch rules from these guards composed with the flag definers above.

instruction JumpEq for [X86_64] : JccRel32 {
    param MNEMONIC: String = "je";
    param CC: bits<8> = 0x84;

    behavior {
        if EFLAGS::zf == zext(0b1, 1) {
            PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
        }
    }
}

instruction JumpNotEq for [X86_64] : JccRel32 {
    param MNEMONIC: String = "jne";
    param CC: bits<8> = 0x85;

    behavior {
        if EFLAGS::zf == zext(0b0, 1) {
            PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
        }
    }
}

instruction JumpLess for [X86_64] : JccRel32 {
    param MNEMONIC: String = "jl";
    param CC: bits<8> = 0x8C;

    behavior {
        if EFLAGS::sf != EFLAGS::of {
            PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
        }
    }
}

instruction JumpGreaterEq for [X86_64] : JccRel32 {
    param MNEMONIC: String = "jge";
    param CC: bits<8> = 0x8D;

    behavior {
        if EFLAGS::sf == EFLAGS::of {
            PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
        }
    }
}

instruction JumpBelow for [X86_64] : JccRel32 {
    param MNEMONIC: String = "jb";
    param CC: bits<8> = 0x82;

    behavior {
        if EFLAGS::cf == zext(0b1, 1) {
            PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
        }
    }
}

instruction JumpAboveEq for [X86_64] : JccRel32 {
    param MNEMONIC: String = "jae";
    param CC: bits<8> = 0x83;

    behavior {
        if EFLAGS::cf == zext(0b0, 1) {
            PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
        }
    }
}

instruction Call for [X86_64] {
    param MNEMONIC: String = "call";

    operands {
        imm: bits<32>,
    }

    encoding {
        0..7 => 0xE8,
        8..39 => imm,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }

    behavior {
        // Push the return address to the new top of stack. Behaviors are
        // parallel-assignment, so the store must name `rsp - 8` explicitly
        // rather than read `rsp` after its own decrement.
        store(GPR::rsp - zext(0b1000, self.XLEN), 8, PC::pc + zext(0b101, self.XLEN));
        GPR::rsp = GPR::rsp - zext(0b1000, self.XLEN);
        PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b101, self.XLEN);
    }
}

instruction Ret for [X86_64] {
    param MNEMONIC: String = "ret";

    encoding {
        0..7 => 0xC3,
    }

    asm {
        "{self.MNEMONIC}"
    }

    behavior {
        PC::pc = load(GPR::rsp, 8, 0b0);
        GPR::rsp = GPR::rsp + zext(0b1000, self.XLEN);
    }
}

instruction MovLoad for [X86_64] {
    param OPNAME: String = "mov_load";
    param MNEMONIC: String = "mov";

    operands {
        dst: GPR,
        base: GPR,
    }

    encoding {
        0 => base[3],
        1 => 0b0,
        2 => dst[3],
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => 0x8B,
        16..18 => base[0..2],
        19..21 => dst[0..2],
        22..23 => 0b00,
    }

    asm {
        "{self.MNEMONIC} {dst}, [{base}]"
    }

    behavior {
        dst = load(base, 8, 0b0);
    }
}

instruction MovStore for [X86_64] {
    param OPNAME: String = "mov_store";
    param MNEMONIC: String = "mov";

    operands {
        base: GPR,
        src: GPR,
    }

    encoding {
        0 => base[3],
        1 => 0b0,
        2 => src[3],
        3 => 0b1,
        4..7 => 0b0100,
        8..15 => 0x89,
        16..18 => base[0..2],
        19..21 => src[0..2],
        22..23 => 0b00,
    }

    asm {
        "{self.MNEMONIC} [{base}], {src}"
    }

    behavior {
        store(base, 8, src);
    }
}

instruction JmpIndirect for [X86_64] {
    param OPNAME: String = "jmp_indirect";
    param MNEMONIC: String = "jmp";

    operands {
        target: GPR,
    }

    encoding {
        0 => target[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0xFF,
        16..18 => target[0..2],
        19..21 => 0b100,
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} *{target}"
    }

    behavior {
        PC::pc = target;
    }
}

instruction CallIndirect for [X86_64] {
    param OPNAME: String = "call_indirect";
    param MNEMONIC: String = "call";

    operands {
        target: GPR,
    }

    encoding {
        0 => target[3],
        1 => 0b0,
        2 => 0b0,
        3 => 0b0,
        4..7 => 0b0100,
        8..15 => 0xFF,
        16..18 => target[0..2],
        19..21 => 0b010,
        22..23 => 0b11,
    }

    asm {
        "{self.MNEMONIC} *{target}"
    }

    behavior {
        // The pushed return address is the next instruction (3 encoded bytes).
        // Parallel assignment: name `rsp - 8` in the store rather than read
        // `rsp` after its own decrement.
        store(GPR::rsp - zext(0b1000, self.XLEN), 8, PC::pc + zext(0b11, self.XLEN));
        GPR::rsp = GPR::rsp - zext(0b1000, self.XLEN);
        PC::pc = target;
    }
}

alu_rr!("32", "32", RegReg32,
    (Add, "add", 0x01, { dst = dst + src; }),
    (Sub, "sub", 0x29, { dst = dst - src; }),
    (And, "and", 0x21, { dst = dst & src; }),
    (Or,  "or",  0x09, { dst = dst | src; }),
    (Xor, "xor", 0x31, { dst = dst ^ src; }),
    (Mov, "mov", 0x89, { dst = src; })
)

alu_ri!("32", "32", RegImm32,
    (AddImm, "add_imm", "add", 0x81, 0b000, { dst = dst + sext(imm, 32); }),
    (OrImm,  "or_imm",  "or",  0x81, 0b001, { dst = dst | sext(imm, 32); }),
    (AndImm, "and_imm", "and", 0x81, 0b100, { dst = dst & sext(imm, 32); }),
    (XorImm, "xor_imm", "xor", 0x81, 0b110, { dst = dst ^ sext(imm, 32); }),
    (MovImm, "mov_imm", "mov", 0xC7, 0b000, { dst = sext(imm, 32); })
)

shift_cl!("32", "32", RegShiftCl32,
    (ShlCl, "shl_cl", "shl", 0b100, { dst = dst << extract(GPR::rcx, 4, 0); }),
    (ShrCl, "shr_cl", "shr", 0b101, { dst = dst >> extract(GPR::rcx, 4, 0); }),
    (SarCl, "sar_cl", "sar", 0b111, { dst = dst >>> extract(GPR::rcx, 4, 0); })
)

shift_imm!("32", "32", RegShift32,
    (ShlImm, "shl", 0b100, { dst = dst << extract(imm, 4, 0); }),
    (ShrImm, "shr", 0b101, { dst = dst >> extract(imm, 4, 0); }),
    (SarImm, "sar", 0b111, { dst = dst >>> extract(imm, 4, 0); })
