// SSE2 scalar double-precision floating point. The sixteen XMM registers are
// modeled at their low 64 bits only (the scalar-double view); the semantic
// engine reads a float-typed register's bits as a binary64 APFloat, so
// `fadd`/`fmul` on XMM operands compute real double results. Upper lanes are
// never read by a scalar op, so tracking them is unnecessary (as with the
// AArch64 `FPR64` view of its 128-bit `v` registers).

register_class XMM for [X86_64] {
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 64;

    registers {
        xmm0 => { index = 0, traits = [float, argument, return_value, caller_saved] },
        xmm1 => { index = 1, traits = [float, argument, return_value, caller_saved] },
        xmm2..xmm7 => { traits = [float, argument, caller_saved] },
        xmm8..xmm15 => { traits = [float, caller_saved] },
    }
}

register_class XMM32 for [X86_64] {
    file = XMM;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 32;

    registers {
        xmm0 => { index = 0, traits = [float, argument, return_value, caller_saved] },
        xmm1 => { index = 1, traits = [float, argument, return_value, caller_saved] },
        xmm2..xmm7 => { traits = [float, argument, caller_saved] },
        xmm8..xmm15 => { traits = [float, caller_saved] },
    }
}

// Low-XMM subclass (xmm0..xmm7) selected post-RA for the REX-free SSE encodings
// GNU as emits when no register-number 4th bit is needed. Shares the XMM file,
// carries no traits, and is never an allocation class (its ops are behavior-free
// and root no isel rule).
register_class XMMlow for [X86_64] {
    file = XMM;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 64;

    registers {
        xmm0 => { index = 0 },
        xmm1 => { index = 1 },
        xmm2 => { index = 2 },
        xmm3 => { index = 3 },
        xmm4 => { index = 4 },
        xmm5 => { index = 5 },
        xmm6 => { index = 6 },
        xmm7 => { index = 7 },
    }
}

// `op xmm_dst, xmm_src`: the F2 mandatory prefix, REX (W=0; R/B carry the 4th
// register-number bits), the 0x0F escape, the opcode, then ModR/M(mod=11,
// reg=dst, rm=src). The op is two-address — dst is also the first source — so
// selection ties it to the destination, matching the `addf`/`subf` shape.
template FpArith for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: XMM,
        src: XMM,
    }

    encoding {
        0..7 => 0xF2,
        8 => src[3],
        9 => 0b0,
        10 => dst[3],
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => 0x0F,
        24..31 => OPCODE,
        32..34 => src[0..2],
        35..37 => dst[0..2],
        38..39 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

template FpArith32 for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: XMM32,
        src: XMM32,
    }

    encoding {
        0..7 => 0xF3,
        8 => src[3],
        9 => 0b0,
        10 => dst[3],
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => 0x0F,
        24..31 => OPCODE,
        32..34 => src[0..2],
        35..37 => dst[0..2],
        38..39 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

// No-REX scalar-double form (xmm0..xmm7): F2 prefix, 0x0F escape, opcode, then
// ModR/M(mod=11, reg=dst, rm=src). Dropping the REX byte shifts the tail up 8
// bits, exactly as the 16-bit 0x66 forms do.
template FpArithNorex for [X86_64] {
    param MNEMONIC: String;
    param OPCODE: bits<8>;

    operands {
        dst: XMMlow,
        src: XMMlow,
    }

    encoding {
        0..7 => 0xF2,
        8..15 => 0x0F,
        16..23 => OPCODE,
        24..26 => src[0..2],
        27..29 => dst[0..2],
        30..31 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }
}

// No-REX SSE forms. Behavior-free: canonicalize target for the low-xmm ALU and
// movsd copies, and the assembler's preferred candidate for xmm0..xmm7.
macro fp_norex {
    ( $( ( $name:ident, $op:literal, $mn:literal, $opc:literal ) ),* ) => {
        $( instruction $name for [X86_64] : FpArithNorex {
               param OPNAME: String = $op;
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { }
           } )*
    };
}

fp_norex!(
    (AddsdNorex, "addsd_norex", "addsd", 0x58),
    (SubsdNorex, "subsd_norex", "subsd", 0x5C),
    (MulsdNorex, "mulsd_norex", "mulsd", 0x59),
    (DivsdNorex, "divsd_norex", "divsd", 0x5E),
    (MovsdNorex, "movsd_norex", "movsd", 0x10)
)

instruction Addsd for [X86_64] : FpArith {
    param MNEMONIC: String = "addsd";
    param OPCODE: bits<8> = 0x58;

    behavior {
        dst = fadd(dst, src);
    }
}

instruction Subsd for [X86_64] : FpArith {
    param MNEMONIC: String = "subsd";
    param OPCODE: bits<8> = 0x5C;

    behavior {
        dst = fsub(dst, src);
    }
}

instruction Mulsd for [X86_64] : FpArith {
    param MNEMONIC: String = "mulsd";
    param OPCODE: bits<8> = 0x59;

    behavior {
        dst = fmul(dst, src);
    }
}

instruction Divsd for [X86_64] : FpArith {
    param MNEMONIC: String = "divsd";
    param OPCODE: bits<8> = 0x5E;

    behavior {
        dst = fdiv(dst, src);
    }
}

instruction Addss for [X86_64] : FpArith32 {
    param MNEMONIC: String = "addss";
    param OPCODE: bits<8> = 0x58;

    behavior {
        dst = fadd(dst, src);
    }
}

instruction Subss for [X86_64] : FpArith32 {
    param MNEMONIC: String = "subss";
    param OPCODE: bits<8> = 0x5C;

    behavior {
        dst = fsub(dst, src);
    }
}

instruction Mulss for [X86_64] : FpArith32 {
    param MNEMONIC: String = "mulss";
    param OPCODE: bits<8> = 0x59;

    behavior {
        dst = fmul(dst, src);
    }
}

instruction Divss for [X86_64] : FpArith32 {
    param MNEMONIC: String = "divss";
    param OPCODE: bits<8> = 0x5E;

    behavior {
        dst = fdiv(dst, src);
    }
}

// `movsd xmm_dst, xmm_src` (F2 0F 10 /r): register-to-register scalar-double
// move. Emitted by register allocation to copy a value before a two-address FP
// op overwrites it; the reg/rm layout matches `FpArith`.
instruction Movsd for [X86_64] {
    param MNEMONIC: String = "movsd";

    operands {
        dst: XMM,
        src: XMM,
    }

    encoding {
        0..7 => 0xF2,
        8 => src[3],
        9 => 0b0,
        10 => dst[3],
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => 0x0F,
        24..31 => 0x10,
        32..34 => src[0..2],
        35..37 => dst[0..2],
        38..39 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }

    behavior {
        dst = src;
    }
}

instruction Movss for [X86_64] : FpArith32 {
    param MNEMONIC: String = "movss";
    param OPCODE: bits<8> = 0x10;

    behavior {
        dst = src;
    }
}

instruction MovdToXmm for [X86_64] {
    param MNEMONIC: String = "movd";
    param OPNAME: String = "movd_xmm";

    operands {
        dst: XMM32,
        src: GPR32,
    }

    encoding {
        0..7 => 0x66,
        8 => src[3],
        9 => 0b0,
        10 => dst[3],
        11 => 0b0,
        12..15 => 0b0100,
        16..23 => 0x0F,
        24..31 => 0x6E,
        32..34 => src[0..2],
        35..37 => dst[0..2],
        38..39 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }

    behavior {
        dst = src;
    }
}

instruction MovqToXmm for [X86_64] {
    param MNEMONIC: String = "movq";
    param OPNAME: String = "movq_xmm";

    operands {
        dst: XMM,
        src: GPR,
    }

    encoding {
        0..7 => 0x66,
        8 => src[3],
        9 => 0b0,
        10 => dst[3],
        11 => 0b1,
        12..15 => 0b0100,
        16..23 => 0x0F,
        24..31 => 0x6E,
        32..34 => src[0..2],
        35..37 => dst[0..2],
        38..39 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {dst}, {src}"
    }

    behavior {
        dst = src;
    }
}
