// Single-shape families (only 64-bit and 32-bit variants, both no-prefix).
macro tmpl_rscl {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0xD3,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, cl" }
        }
    };
    // No REX: 0xD3 + ModR/M (32-bit low registers).
    ( $name:ident, $cls:ident, norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0..7 => 0xD3,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, cl" }
        }
    };
    // 0x66 prefix, no REX (16-bit low registers).
    ( $name:ident, $cls:ident, prefix66norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0..7 => 0x66,
                8..15 => 0xD3,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, cl" }
        }
    };
    // No REX: 0xD2 + ModR/M (8-bit low registers al/cl/dl/bl).
    ( $name:ident, $cls:ident, bytenorex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0..7 => 0xD2,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, cl" }
        }
    };
}

macro tmpl_rrext {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0 => src[3],
                1 => 0b0,
                2 => dst[3],
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0x0F,
                16..23 => OPCODE,
                24..26 => src[0..2],
                27..29 => dst[0..2],
                30..31 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
}

macro tmpl_rrimm {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, imm: bits<32>, }
            encoding {
                0 => src[3],
                1 => 0b0,
                2 => dst[3],
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => src[0..2],
                19..21 => dst[0..2],
                22..23 => 0b11,
                24..55 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {src}, {imm}" }
        }
    };
}

// Condition-code families. Each row carries its guard expression verbatim as a
// `{ ... }` token fragment, so original parenthesization is preserved. jcc
// writes PC, setcc writes an 8-bit 0/1, cmovcc selects src/dst.

macro jcc_ops {
    ( $( ( $name:ident, $mn:literal, $cc:literal, { $($cond:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : JccRel32 {
               param MNEMONIC: String = $mn;
               param CC: bits<8> = $cc;
               behavior {
                   if $($cond)* {
                       PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
                   }
               }
           } )*
    };
}

macro setcc_ops {
    ( $( ( $name:ident, $mn:literal, $cc:literal, { $($cond:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : SetccReg {
               param MNEMONIC: String = $mn;
               param CC: bits<8> = $cc;
               behavior {
                   dst = if $($cond)* {
                       zext(0b1, 8)
                   } else {
                       zext(0b0, 8)
                   };
               }
           } )*
    };
}

// No-REX setcc forms (al/cl/dl/bl). Behavior-free (canonicalize-only).
macro setcc_norex {
    ( $( ( $name:ident, $op:literal, $mn:literal, $cc:literal ) ),* ) => {
        $( instruction $name for [X86_64] : SetccRegNorex {
               param OPNAME: String = $op;
               param MNEMONIC: String = $mn;
               param CC: bits<8> = $cc;
               behavior { }
           } )*
    };
}

macro cmovcc_ops {
    ( $( ( $name:ident, $mn:literal, $opc:literal, { $($cond:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : RegRegExt {
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior {
                   dst = if $($cond)* {
                       src
                   } else {
                       dst
                   };
               }
           } )*
    };
}

// Flag-computation statement macros for compare/test. `$rhs` is the second
// operand (a register or a sign-extended immediate); `$w`/`$msb` are the operand
// width and its most-significant bit index. Guards are passed as `{ ... }`
// fragments so parenthesization round-trips exactly.

macro sub_flags {
    ( { $($rhs:tt)* }, { $($msb:tt)* } ) => {
        EFLAGS::cf = if dst ~< $($rhs)* {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::zf = if dst == $($rhs)* {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::sf = extract(dst - $($rhs)*, $($msb)*, $($msb)*);
        EFLAGS::of = extract((dst ^ $($rhs)*) & (dst ^ (dst - $($rhs)*)), $($msb)*, $($msb)*);
    };
}

macro test_flags {
    ( { $($rhs:tt)* }, { $($w:tt)* }, { $($msb:tt)* } ) => {
        EFLAGS::cf = zext(0b0, 1);
        EFLAGS::zf = if (dst & $($rhs)*) == zext(0b0, $($w)*) {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::sf = extract(dst & $($rhs)*, $($msb)*, $($msb)*);
        EFLAGS::of = zext(0b0, 1);
    };
}

// Group-3 unary `op r/m` (0xF7 /digit) and the movzx/movsx register extensions
// (0x0F escape, narrow source in rm). Both come in 64/32 and 8/16-source pairs.
macro tmpl_runary {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0xF7,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}" }
        }
    };
    // No REX: 0xF7 + ModR/M (32-bit low registers).
    ( $name:ident, $cls:ident, norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0..7 => 0xF7,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}" }
        }
    };
    // 0x66 prefix, no REX (16-bit low registers).
    ( $name:ident, $cls:ident, prefix66norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0..7 => 0x66,
                8..15 => 0xF7,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}" }
        }
    };
    // No REX: 0xF6 + ModR/M (8-bit low registers al/cl/dl/bl).
    ( $name:ident, $cls:ident, bytenorex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0..7 => 0xF6,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}" }
        }
    };
}

macro tmpl_extend {
    ( $name:ident, $cls:ident ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: GPR, src: $cls, }
            encoding {
                0 => src[3],
                1 => 0b0,
                2 => dst[3],
                3 => 0b1,
                4..7 => 0b0100,
                8..15 => 0x0F,
                16..23 => OPCODE,
                24..26 => src[0..2],
                27..29 => dst[0..2],
                30..31 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
}

// REX-prefix scaffold: the 0100 WRXB byte laid out little-endian. `$b0` is the
// rm/base 4th-bit source, `$b2` the reg 4th-bit source (each a slice like
// `base[3]` or a literal `0b0`), `$w` the REX.W bit. Expands to the five encoding
// arms (with a trailing comma) so the remaining arms follow directly.
macro rex {
    ( { $($b0:tt)* }, { $($b2:tt)* }, $w:literal ) => {
        0 => $($b0)*,
        1 => 0b0,
        2 => $($b2)*,
        3 => $w,
        4..7 => 0b0100,
    };
}

// movzx/movsx register extensions. Source width picks the template, so it is a
// per-row parameter rather than a width group.
macro extend_ops {
    ( $( ( $name:ident, $opname:literal, $mn:literal, $tmpl:ident, $opc:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $opname;
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { $($b)* }
           } )*
    };
}
