            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0xC0,
                8..9 => dst[0..1],
                10 => 0b1,
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    // No REX: 0xC1 + ModR/M + imm8 (32-bit low registers).
    ( $name:ident, $cls:ident, norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0xC1,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    // 0x66 prefix, no REX (16-bit low registers).
    ( $name:ident, $cls:ident, prefix66norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0x66,
                8..15 => 0xC1,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    // No REX: 0xC0 + ModR/M + imm8 (8-bit low registers al/cl/dl/bl).
    ( $name:ident, $cls:ident, bytenorex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0xC0,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
