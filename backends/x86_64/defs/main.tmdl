    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => 0b0,
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => 0x83,
                24..26 => dst[0..2],
                27..29 => EXT,
                30..31 => 0b11,
                32..39 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0x83,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0x66,
                8..15 => 0x83,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
}

macro tmpl_rs {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal, opcode = $opc:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => $opc,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
