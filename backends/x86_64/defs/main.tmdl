// x86-64 prototype, Intel syntax. Scope: the sixteen 64-bit GPRs with a fixed
// REX.W prefix. r8..r15 carry the 4th register-number bit in the REX prefix
// (REX.R for the ModR/M reg field, REX.B for the rm field); the low three bits
// stay in ModR/M. Register operands are spliced across both fields via slices,
// e.g. `dst[0..2]` and `dst[3]`.

isa X86_64 {
    param XLEN: Integer = 64;
}

isa X86 requires [X86_64] {}

register_class PC for [X86_64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

// Status flags written by compare-style instructions and read by conditional
// jumps. Only the four flags the jcc family consumes are modeled (cf/zf/sf/of);
// af/pf are omitted until an instruction reads them. The registers carry no
// encoding slots, so the class is never allocated.
register_class EFLAGS for [X86_64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = 1;

    registers {
        cf => { traits = [status_flag] },
        zf => { traits = [status_flag] },
        sf => { traits = [status_flag] },
        of => { traits = [status_flag] },
    }
}

// Names carry no trailing digit, so each declares its register number.
register_class GPR for [X86_64] {
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = self.XLEN;

    registers {
        rax => { index = 0, traits = [return_value, caller_saved] },
        rcx => { index = 1, arg = 3, traits = [argument, caller_saved] },
        rdx => { index = 2, arg = 2, traits = [argument, return_value, caller_saved] },
        rbx => { index = 3, traits = [callee_saved] },
        rsp => { index = 4, traits = [stack_pointer, callee_saved] },
        rbp => { index = 5, traits = [callee_saved] },
        rsi => { index = 6, arg = 1, traits = [argument, caller_saved] },
        rdi => { index = 7, arg = 0, traits = [argument, caller_saved] },
        r8 => { index = 8, arg = 4, traits = [argument, caller_saved] },
        r9 => { index = 9, arg = 5, traits = [argument, caller_saved] },
        r10 => { index = 10, traits = [caller_saved] },
        r11 => { index = 11, traits = [caller_saved] },
        r12 => { index = 12, traits = [callee_saved] },
        r13 => { index = 13, traits = [callee_saved] },
        r14 => { index = 14, traits = [callee_saved] },
        r15 => { index = 15, traits = [callee_saved] },
    }
}

register_class GPR32 for [X86] : GPR {
    param WIDTH: Integer = 32;

    registers {
        eax => { index = 0, traits = [return_value, caller_saved] },
        ecx => { index = 1, arg = 3, traits = [argument, caller_saved] },
        edx => { index = 2, arg = 2, traits = [argument, return_value, caller_saved] },
        ebx => { index = 3, traits = [callee_saved] },
        esp => { index = 4, traits = [stack_pointer, callee_saved] },
        ebp => { index = 5, traits = [callee_saved] },
        esi => { index = 6, arg = 1, traits = [argument, caller_saved] },
        edi => { index = 7, arg = 0, traits = [argument, caller_saved] },
        r8d => { index = 8, arg = 4, traits = [argument, caller_saved] },
        r9d => { index = 9, arg = 5, traits = [argument, caller_saved] },
        r10d => { index = 10, traits = [caller_saved] },
        r11d => { index = 11, traits = [caller_saved] },
        r12d => { index = 12, traits = [callee_saved] },
        r13d => { index = 13, traits = [callee_saved] },
        r14d => { index = 14, traits = [callee_saved] },
        r15d => { index = 15, traits = [callee_saved] },
    }
}

register_class GPR16 for [X86] : GPR {
    param WIDTH: Integer = 16;

    registers {
        ax => { index = 0, traits = [return_value, caller_saved] },
        cx => { index = 1, arg = 3, traits = [argument, caller_saved] },
        dx => { index = 2, arg = 2, traits = [argument, return_value, caller_saved] },
        bx => { index = 3, traits = [callee_saved] },
        sp => { index = 4, traits = [stack_pointer, callee_saved] },
        bp => { index = 5, traits = [callee_saved] },
        si => { index = 6, arg = 1, traits = [argument, caller_saved] },
        di => { index = 7, arg = 0, traits = [argument, caller_saved] },
        r8w => { index = 8, arg = 4, traits = [argument, caller_saved] },
        r9w => { index = 9, arg = 5, traits = [argument, caller_saved] },
        r10w => { index = 10, traits = [caller_saved] },
        r11w => { index = 11, traits = [caller_saved] },
        r12w => { index = 12, traits = [callee_saved] },
        r13w => { index = 13, traits = [callee_saved] },
        r14w => { index = 14, traits = [callee_saved] },
        r15w => { index = 15, traits = [callee_saved] },
    }
}

// spl/bpl/sil/dil and r8b..r15b are encodable only with a REX prefix, which the
// templates always emit.
register_class GPR8 for [X86] : GPR {
    param WIDTH: Integer = 8;

    registers {
        al => { index = 0, traits = [return_value, caller_saved] },
        cl => { index = 1, arg = 3, traits = [argument, caller_saved] },
        dl => { index = 2, arg = 2, traits = [argument, return_value, caller_saved] },
        bl => { index = 3, traits = [callee_saved] },
        spl => { index = 4, traits = [stack_pointer, callee_saved] },
        bpl => { index = 5, traits = [callee_saved] },
        sil => { index = 6, arg = 1, traits = [argument, caller_saved] },
        dil => { index = 7, arg = 0, traits = [argument, caller_saved] },
        r8b => { index = 8, arg = 4, traits = [argument, caller_saved] },
        r9b => { index = 9, arg = 5, traits = [argument, caller_saved] },
        r10b => { index = 10, traits = [caller_saved] },
        r11b => { index = 11, traits = [caller_saved] },
        r12b => { index = 12, traits = [callee_saved] },
        r13b => { index = 13, traits = [callee_saved] },
        r14b => { index = 14, traits = [callee_saved] },
        r15b => { index = 15, traits = [callee_saved] },
    }
}

// ah/ch/dh/bh overlap bits 8..15 of rax..rbx, so they alias the GPR file at
// indices 0..3 (`file = GPR` shares the file without importing its registers).
// Their ModR/M numbers 4..7 are encodable only without a REX prefix.
register_class GPR8H for [X86] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 8;

    registers {
        ah => { index = 0, traits = [caller_saved] },
        ch => { index = 1, traits = [caller_saved] },
        dh => { index = 2, traits = [caller_saved] },
        bh => { index = 3, traits = [callee_saved] },
    }
}

// `op dst, src`: REX.W + opcode + ModR/M(mod=11, reg=src, rm=dst). The REX byte
// is 0100 WRXB: REX.B carries dst's 4th bit, REX.R carries src's.
tmpl_rr!(RegReg, X86_64, GPR, rexw = 0b1)

// `op dst, imm32`: REX.W + opcode + ModR/M(mod=11, reg=EXT, rm=dst) + imm32. The
// reg field holds the /digit extension, so only REX.B (dst's 4th bit) varies.
tmpl_ri!(RegImm, X86_64, GPR, rexw = 0b1)

// Three-operand `imul r64, r/m64, imm32` (0x69 /r id): the non-destructive
// immediate multiply. ModR/M.reg carries dst (REX.R), rm carries src (REX.B) —
// the `RegRegExt` layout, but with a single-byte opcode and a trailing imm32.
tmpl_rrimm!(RegRegImm, X86_64, GPR, rexw = 0b1)

// `op dst, imm8`: REX.W + 0xC1 + ModR/M(mod=11, reg=EXT, rm=dst) + imm8.
tmpl_rs!(RegShift, X86_64, GPR, rexw = 0b1, opcode = 0xC1)

// `op dst, cl`: REX.W + 0xD3 + ModR/M(mod=11, reg=EXT, rm=dst). The count is
// the low bits of rcx, masked to the operand width as in hardware. The cl
// forms must be declared before the matching immediate forms: an immediate
// operand also accepts a bare identifier (as a symbol reference), so the
// immediate form would otherwise swallow the literal `cl`.
tmpl_rscl!(RegShiftCl, X86_64, GPR, rexw = 0b1)

tmpl_rscl!(RegShiftCl32, X86, GPR32, rexw = 0b0)

// `op dst, src` behind the 0x0F opcode escape, with the ModR/M fields swapped
// relative to `RegReg`: reg carries dst (REX.R), rm carries src (REX.B) — the
// `imul r64, r/m64` layout.
tmpl_rrext!(RegRegExt, X86_64, GPR, rexw = 0b1)

tmpl_rrext!(RegRegExt32, X86, GPR32, rexw = 0b0)

tmpl_rr!(RegReg32, X86, GPR32, rexw = 0b0)

tmpl_ri!(RegImm32, X86, GPR32, rexw = 0b0)

// 32-bit `imul r32, r/m32, imm32` (0x69 /r id, no REX.W).
tmpl_rrimm!(RegRegImm32, X86, GPR32, rexw = 0b0)

tmpl_rs!(RegShift32, X86, GPR32, rexw = 0b0, opcode = 0xC1)

// 16-bit forms prepend the 0x66 operand-size prefix to the 32-bit encoding.
tmpl_rr!(RegReg16, GPR16, prefix66)

tmpl_ri!(RegImm16, GPR16, prefix66)

tmpl_rs!(RegShift16, GPR16, prefix66)

// 8-bit forms reuse the 32-bit layout with the byte-sized opcode.
tmpl_rr!(RegReg8, X86, GPR8, rexw = 0b0)

tmpl_ri!(RegImm8, GPR8, byte)

tmpl_rs!(RegShift8, X86, GPR8, rexw = 0b0, opcode = 0xC0)

// No REX prefix: just opcode + ModR/M. The field's high bit turns the register
// index (0..3) into its ModR/M number (4..7).
tmpl_rr!(RegReg8H, GPR8H, high8)

tmpl_ri!(RegImm8H, GPR8H, high8)

tmpl_rs!(RegShift8H, GPR8H, high8)

// `jcc rel32`: the 0x0F opcode escape, 0x80|cc, then a 32-bit displacement
// measured from the end of the 6-byte instruction (RIP already points past the
// branch when the displacement applies — hence the `+ 6` in the behaviors).
template JccRel32 for [X86_64] {
    param MNEMONIC: String;
    param CC: bits<8>;

    operands {
        imm: bits<32>,
    }

    encoding {
        0..7 => 0x0F,
        8..15 => CC,
        16..47 => imm,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

// Width-family macros for the group-1 ALU / immediate / shift instructions.
// Each family has a width-suffixed arm (for [X86], carries an OPNAME derived by
// ${concat}) and a 64-bit arm (for [X86_64], no width suffix). One invocation
// per width group keeps generated items in their original declaration order.
// Opcodes differ per width (e.g. Add 0x01 vs Add8 0x00), so they stay per row.

macro alu_rr {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $mn:literal, $opc:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86] : $tmpl {
               param OPNAME: String = ${concat($mn, $osuf)};
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $mn:literal, $opc:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { $($b)* }
           } )*
    };
}

macro alu_ri {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $ostem:literal, $mn:literal, $opc:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86] : $tmpl {
               param OPNAME: String = ${concat($ostem, $osuf)};
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $opname:literal, $mn:literal, $opc:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $opname;
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

macro shift_cl {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $ostem:literal, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86] : $tmpl {
               param OPNAME: String = ${concat($ostem, $osuf)};
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $opname:literal, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $opname;
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

macro shift_imm {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86] : $tmpl {
               param OPNAME: String = ${concat($mn, $osuf)};
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

// Template-family macros. x86 width variants share a ModR/M scaffold but the
// encoding *shape* changes with width: REX.W is a bit param (64 vs 32/8), the
// 0x66 operand-size prefix (16-bit) shifts every offset by 8, and the 8-bit
// high-byte forms drop REX entirely. One arm per shape, each writing its offsets
// once. Templates emit no code themselves, so only the derived instructions
// matter for output.

macro tmpl_rr {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => src[3],
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => src[0..2],
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => src[3],
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => OPCODE,
                24..26 => dst[0..2],
                27..29 => src[0..2],
                30..31 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
    ( $name:ident, $cls:ident, high8 ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0..7 => OPCODE,
                8..9 => dst[0..1],
                10 => 0b1,
                11..12 => src[0..1],
                13 => 0b1,
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
}

macro tmpl_ri {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<32>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..55 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, byte ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => 0b0,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<16>, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => 0b0,
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => OPCODE,
                24..26 => dst[0..2],
                27..29 => EXT,
                30..31 => 0b11,
                32..47 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, high8 ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => OPCODE,
                8..9 => dst[0..1],
                10 => 0b1,
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
}

macro tmpl_rs {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal, opcode = $opc:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => $opc,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => 0b0,
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => 0xC1,
                24..26 => dst[0..2],
                27..29 => EXT,
                30..31 => 0b11,
                32..39 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, high8 ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0xC0,
                8..9 => dst[0..1],
                10 => 0b1,
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
}

// Single-shape families (only 64-bit and 32-bit variants, both no-prefix).
macro tmpl_rscl {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0xD3,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, cl" }
        }
    };
}

macro tmpl_rrext {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0 => src[3],
                1 => 0b0,
                2 => dst[3],
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0x0F,
                16..23 => OPCODE,
                24..26 => src[0..2],
                27..29 => dst[0..2],
                30..31 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
}

macro tmpl_rrimm {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, imm: bits<32>, }
            encoding {
                0 => src[3],
                1 => 0b0,
                2 => dst[3],
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => src[0..2],
                19..21 => dst[0..2],
                22..23 => 0b11,
                24..55 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {src}, {imm}" }
        }
    };
}

// Condition-code families. Each row carries its guard expression verbatim as a
// `{ ... }` token fragment, so original parenthesization is preserved. jcc
// writes PC, setcc writes an 8-bit 0/1, cmovcc selects src/dst.

macro jcc_ops {
    ( $( ( $name:ident, $mn:literal, $cc:literal, { $($cond:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : JccRel32 {
               param MNEMONIC: String = $mn;
               param CC: bits<8> = $cc;
               behavior {
                   if $($cond)* {
                       PC::pc = PC::pc + sext(imm, self.XLEN) + zext(0b110, self.XLEN);
                   }
               }
           } )*
    };
}

macro setcc_ops {
    ( $( ( $name:ident, $mn:literal, $cc:literal, { $($cond:tt)* } ) ),* ) => {
        $( instruction $name for [X86] : SetccReg {
               param MNEMONIC: String = $mn;
               param CC: bits<8> = $cc;
               behavior {
                   dst = if $($cond)* {
                       zext(0b1, 8)
                   } else {
                       zext(0b0, 8)
                   };
               }
           } )*
    };
}

macro cmovcc_ops {
    ( $( ( $name:ident, $mn:literal, $opc:literal, { $($cond:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : RegRegExt {
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior {
                   dst = if $($cond)* {
                       src
                   } else {
                       dst
                   };
               }
           } )*
    };
}

// Flag-computation statement macros for compare/test. `$rhs` is the second
// operand (a register or a sign-extended immediate); `$w`/`$msb` are the operand
// width and its most-significant bit index. Guards are passed as `{ ... }`
// fragments so parenthesization round-trips exactly.

macro sub_flags {
    ( { $($rhs:tt)* }, { $($msb:tt)* } ) => {
        EFLAGS::cf = if dst ~< $($rhs)* {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::zf = if dst == $($rhs)* {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::sf = extract(dst - $($rhs)*, $($msb)*, $($msb)*);
        EFLAGS::of = extract((dst ^ $($rhs)*) & (dst ^ (dst - $($rhs)*)), $($msb)*, $($msb)*);
    };
}

macro test_flags {
    ( { $($rhs:tt)* }, { $($w:tt)* }, { $($msb:tt)* } ) => {
        EFLAGS::cf = zext(0b0, 1);
        EFLAGS::zf = if (dst & $($rhs)*) == zext(0b0, $($w)*) {
            zext(0b1, 1)
        } else {
            zext(0b0, 1)
        };
        EFLAGS::sf = extract(dst & $($rhs)*, $($msb)*, $($msb)*);
        EFLAGS::of = zext(0b0, 1);
    };
}

// Group-3 unary `op r/m` (0xF7 /digit) and the movzx/movsx register extensions
// (0x0F escape, narrow source in rm). Both come in 64/32 and 8/16-source pairs.
macro tmpl_runary {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0xF7,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}" }
        }
    };
}

macro tmpl_extend {
    ( $name:ident, $cls:ident ) => {
        template $name for [X86] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: GPR, src: $cls, }
            encoding {
                0 => src[3],
                1 => 0b0,
                2 => dst[3],
                3 => 0b1,
                4..7 => 0b0100,
                8..15 => 0x0F,
                16..23 => OPCODE,
                24..26 => src[0..2],
                27..29 => dst[0..2],
                30..31 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
}

// movzx/movsx register extensions. Source width picks the template, so it is a
// per-row parameter rather than a width group.
macro extend_ops {
    ( $( ( $name:ident, $opname:literal, $mn:literal, $tmpl:ident, $opc:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86] : $tmpl {
               param OPNAME: String = $opname;
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { $($b)* }
           } )*
    };
}
