//! x86-64 architectural registers and System V calling convention, using Intel syntax.

// x86-64 prototype, Intel syntax. Scope: the sixteen 64-bit GPRs with a fixed
// REX.W prefix. r8..r15 carry the 4th register-number bit in the REX prefix
// (REX.R for the ModR/M reg field, REX.B for the rm field); the low three bits
// stay in ModR/M. Register operands are spliced across both fields via slices,
// e.g. `dst[0..2]` and `dst[3]`.

isa X86 {}

isa X86_64 requires [X86] {
    param XLEN: Integer = 64;
}

register_class PC for [X86_64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

// Status flags written by compare-style instructions and read by conditional
// jumps. Only the four flags the jcc family consumes are modeled (cf/zf/sf/of);
// af/pf are omitted until an instruction reads them. The registers carry no
// encoding slots, so the class is never allocated.
register_class EFLAGS for [X86_64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = 1;

    registers {
        cf => { traits = [status_flag] },
        zf => { traits = [status_flag] },
        sf => { traits = [status_flag] },
        of => { traits = [status_flag] },
    }
}

// Names carry no trailing digit, so each declares its register number.
register_class GPR for [X86_64] {
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = self.XLEN;

    registers {
        rax => { index = 0 },
        rcx => { index = 1 },
        rdx => { index = 2 },
        rbx => { index = 3 },
        rsp => { index = 4 },
        rbp => { index = 5 },
        rsi => { index = 6 },
        rdi => { index = 7 },
        r8 => { index = 8 },
        r9 => { index = 9 },
        r10 => { index = 10 },
        r11 => { index = 11 },
        r12 => { index = 12 },
        r13 => { index = 13 },
        r14 => { index = 14 },
        r15 => { index = 15 },
    }
}

abi SysV("sysv") for [X86_64] {
    stack {
        align = 16;
        grows = down;
        red_zone = 128;
        slot_size = 8;
        save_style = push_pop;
    }
    sp = GPR::rsp;
    fp = GPR::rbp;
    args int -> [GPR::rdi, GPR::rsi, GPR::rdx, GPR::rcx, GPR::r8, GPR::r9],
        then stack;
    args float -> [XMM::xmm0..XMM::xmm7], then stack;
    args vector -> [XMM::xmm0..XMM::xmm7], then stack;
    rets int -> [GPR::rax, GPR::rdx];
    rets float -> [XMM::xmm0, XMM::xmm1];
    rets vector -> [XMM::xmm0, XMM::xmm1];
    callee_saved = [GPR::rbx, GPR::rbp, GPR::r12..GPR::r15];
    reserved = [];
    classifier = sysv;
}

register_class GPR32 for [X86_64] : GPR {
    param WIDTH: Integer = 32;

    registers {
        eax => { index = 0 },
        ecx => { index = 1 },
        edx => { index = 2 },
        ebx => { index = 3 },
        esp => { index = 4 },
        ebp => { index = 5 },
        esi => { index = 6 },
        edi => { index = 7 },
        r8d => { index = 8 },
        r9d => { index = 9 },
        r10d => { index = 10 },
        r11d => { index = 11 },
        r12d => { index = 12 },
        r13d => { index = 13 },
        r14d => { index = 14 },
        r15d => { index = 15 },
    }
}

register_class GPR16 for [X86_64] : GPR {
    param WIDTH: Integer = 16;
    param WRITE_POLICY: String = "merge";

    registers {
        ax => { index = 0 },
        cx => { index = 1 },
        dx => { index = 2 },
        bx => { index = 3 },
        sp => { index = 4 },
        bp => { index = 5 },
        si => { index = 6 },
        di => { index = 7 },
        r8w => { index = 8 },
        r9w => { index = 9 },
        r10w => { index = 10 },
        r11w => { index = 11 },
        r12w => { index = 12 },
        r13w => { index = 13 },
        r14w => { index = 14 },
        r15w => { index = 15 },
    }
}

// spl/bpl/sil/dil and r8b..r15b are encodable only with a REX prefix, which the
// templates always emit.
register_class GPR8 for [X86_64] : GPR {
    param WIDTH: Integer = 8;
    param WRITE_POLICY: String = "merge";

    registers {
        al => { index = 0 },
        cl => { index = 1 },
        dl => { index = 2 },
        bl => { index = 3 },
        spl => { index = 4 },
        bpl => { index = 5 },
        sil => { index = 6 },
        dil => { index = 7 },
        r8b => { index = 8 },
        r9b => { index = 9 },
        r10b => { index = 10 },
        r11b => { index = 11 },
        r12b => { index = 12 },
        r13b => { index = 13 },
        r14b => { index = 14 },
        r15b => { index = 15 },
    }
}

// ah/ch/dh/bh overlap bits 8..15 of rax..rbx, so they alias the GPR file at
// indices 0..3 (`file = GPR` shares the file without importing its registers).
// Their ModR/M numbers 4..7 are encodable only without a REX prefix.
register_class GPR8H for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 8;
    param WRITE_POLICY: String = "merge";
    param BIT_OFFSET: Integer = 8;

    registers {
        ah => { index = 0 },
        ch => { index = 1 },
        dh => { index = 2 },
        bh => { index = 3 },
    }
}

// Low-register subclasses selected post-RA by `canonicalize_encodings` for the
// REX-free encodings GNU as emits when no register-number 4th bit and no
// REX.W/8-bit-spl are needed. Like the memory views below they share the GPR
// file, carry no `argument` traits (so `default_integer_class` is unaffected),
// and are never allocation classes: no instruction over them has a behavior, so
// they root no isel rule and are reachable only through canonicalization.
//   GPR32low/GPR16low: eax..edi / ax..di (indices 0-7) — a REX-free 32/16-bit op.
//   GPR8low: al/cl/dl/bl (indices 0-3) — the only 8-bit registers with no REX;
//   spl/bpl/sil/dil (4-7) still require an empty REX and stay on the GPR8 form.
register_class GPRlow for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = self.XLEN;

    registers {
        rax => { index = 0 },
        rcx => { index = 1 },
        rdx => { index = 2 },
        rbx => { index = 3 },
        rsp => { index = 4 },
        rbp => { index = 5 },
        rsi => { index = 6 },
        rdi => { index = 7 },
    }
}

register_class GPR32low for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 32;

    registers {
        eax => { index = 0 },
        ecx => { index = 1 },
        edx => { index = 2 },
        ebx => { index = 3 },
        esp => { index = 4 },
        ebp => { index = 5 },
        esi => { index = 6 },
        edi => { index = 7 },
    }
}

register_class GPR16low for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 16;
    param WRITE_POLICY: String = "merge";

    registers {
        ax => { index = 0 },
        cx => { index = 1 },
        dx => { index = 2 },
        bx => { index = 3 },
        sp => { index = 4 },
        bp => { index = 5 },
        si => { index = 6 },
        di => { index = 7 },
    }
}

register_class GPR8low for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = 8;
    param WRITE_POLICY: String = "merge";

    registers {
        al => { index = 0 },
        cl => { index = 1 },
        dl => { index = 2 },
        bl => { index = 3 },
    }
}

// Memory-base operand views over the GPR file, selected post-RA when a base
// register lands on a ModR/M escape. Neither carries `argument` traits, so
// `default_integer_class` still resolves to GPR; they share the file
// (`file = GPR`) and alias index-for-index, and are never allocation classes.

// rsp (4) and r12 (12) share ModR/M low bits 100, which as a memory operand's rm
// field means "a SIB byte follows". A base here selects a `_sib` variant.
register_class GPRsib for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = self.XLEN;

    registers {
        rsp => { index = 4 },
        r12 => { index = 12 },
    }
}

// rbp (5) and r13 (13) share ModR/M low bits 101, which with mod=00 means
// RIP-relative disp32. A base here selects a `_rbp` variant (mod=01, disp8=0).
register_class GPRrbp for [X86_64] {
    file = GPR;
    param ENCODING_LEN: Integer = 4;
    param WIDTH: Integer = self.XLEN;

    registers {
        rbp => { index = 5 },
        r13 => { index = 13 },
    }
}

// `op dst, src`: REX.W + opcode + ModR/M(mod=11, reg=src, rm=dst). The REX byte
// is 0100 WRXB: REX.B carries dst's 4th bit, REX.R carries src's.
tmpl_rr!(RegReg, X86_64, GPR, rexw = 0b1)

// `op dst, imm32`: REX.W + opcode + ModR/M(mod=11, reg=EXT, rm=dst) + imm32. The
// reg field holds the /digit extension, so only REX.B (dst's 4th bit) varies.
tmpl_ri!(RegImm, X86_64, GPR, rexw = 0b1)

// Three-operand `imul r64, r/m64, imm32` (0x69 /r id): the non-destructive
// immediate multiply. ModR/M.reg carries dst (REX.R), rm carries src (REX.B) —
// the `RegRegExt` layout, but with a single-byte opcode and a trailing imm32.
tmpl_rrimm!(RegRegImm, X86_64, GPR, rexw = 0b1)

// `op dst, imm8`: REX.W + 0xC1 + ModR/M(mod=11, reg=EXT, rm=dst) + imm8.
tmpl_rs!(RegShift, X86_64, GPR, rexw = 0b1, opcode = 0xC1)

// `op dst, cl`: REX.W + 0xD3 + ModR/M(mod=11, reg=EXT, rm=dst). The count is
// the low bits of rcx, masked to the operand width as in hardware. The cl
// forms must be declared before the matching immediate forms: an immediate
// operand also accepts a bare identifier (as a symbol reference), so the
// immediate form would otherwise swallow the literal `cl`.
tmpl_rscl!(RegShiftCl, X86_64, GPR, rexw = 0b1)

tmpl_rscl!(RegShiftCl32, X86_64, GPR32, rexw = 0b0)

// No-REX by-cl shift templates over the low subclasses (0xD3 / 0x66+0xD3 /
// 0xD2). The cl operand is fixed; only the dst register gates the REX drop.
tmpl_rscl!(RegShiftCl32Norex, GPR32low, norex)

tmpl_rscl!(RegShiftCl16Norex, GPR16low, prefix66norex)

tmpl_rscl!(RegShiftCl8Norex, GPR8low, bytenorex)

// `op dst, src` behind the 0x0F opcode escape, with the ModR/M fields swapped
// relative to `RegReg`: reg carries dst (REX.R), rm carries src (REX.B) — the
// `imul r64, r/m64` layout.
tmpl_rrext!(RegRegExt, X86_64, GPR, rexw = 0b1)

tmpl_rrext!(RegRegExt32, X86_64, GPR32, rexw = 0b0)

tmpl_rr!(RegReg32, X86_64, GPR32, rexw = 0b0)

tmpl_ri!(RegImm32, X86_64, GPR32, rexw = 0b0)

// 32-bit `imul r32, r/m32, imm32` (0x69 /r id, no REX.W).
tmpl_rrimm!(RegRegImm32, X86_64, GPR32, rexw = 0b0)

tmpl_rs!(RegShift32, X86_64, GPR32, rexw = 0b0, opcode = 0xC1)

// 16-bit forms prepend the 0x66 operand-size prefix to the 32-bit encoding.
tmpl_rr!(RegReg16, GPR16, prefix66)

tmpl_ri!(RegImm16, GPR16, prefix66)

tmpl_rs!(RegShift16, GPR16, prefix66)

// No-REX register/register forms over the low subclasses.
tmpl_rr!(RegReg32Norex, GPR32low, norex)

tmpl_rr!(RegReg16Norex, GPR16low, prefix66norex)

tmpl_rr!(RegReg8Norex, GPR8low, norex)

// 8-bit forms reuse the 32-bit layout with the byte-sized opcode.
tmpl_rr!(RegReg8, X86_64, GPR8, rexw = 0b0)

tmpl_ri!(RegImm8, GPR8, byte)

tmpl_rs!(RegShift8, X86_64, GPR8, rexw = 0b0, opcode = 0xC0)

// No-REX shift-by-immediate templates over the low subclasses.
tmpl_rs!(RegShift32Norex, GPR32low, norex)

tmpl_rs!(RegShift16Norex, GPR16low, prefix66norex)

tmpl_rs!(RegShift8Norex, GPR8low, bytenorex)

// No REX prefix: just opcode + ModR/M. The field's high bit turns the register
// index (0..3) into its ModR/M number (4..7).
tmpl_rr!(RegReg8H, GPR8H, high8)

tmpl_ri!(RegImm8H, GPR8H, high8)

tmpl_rs!(RegShift8H, GPR8H, high8)

// No-REX register/immediate templates over the low subclasses.
tmpl_ri!(RegImm32Norex, GPR32low, norex)

tmpl_ri!(RegImm16Norex, GPR16low, prefix66norex)

tmpl_ri!(RegImm8Norex, GPR8low, bytenorex)

// Group-1 0x83 imm8 short-form templates (REX.W / plain / 0x66 / REX-free).
tmpl_ri8!(RegImm8s, X86_64, GPR, rexw = 0b1)

tmpl_ri8!(RegImm8s32, X86_64, GPR32, rexw = 0b0)

tmpl_ri8!(RegImm8s16, GPR16, prefix66)

tmpl_ri8!(RegImm8s32Norex, GPR32low, norex)

tmpl_ri8!(RegImm8s16Norex, GPR16low, prefix66norex)

// `jcc rel32`: the 0x0F opcode escape, 0x80|cc, then a 32-bit displacement
// measured from the end of the 6-byte instruction (RIP already points past the
// branch when the displacement applies — hence the `+ 6` in the behaviors).
template JccRel32 for [X86_64] {
    param MNEMONIC: String;
    param CC: bits<8>;

    operands {
        imm: bits<32>,
    }

    encoding {
        0..7 => 0x0F,
        8..15 => CC,
        16..47 => imm,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

// Width-family macros for the group-1 ALU / immediate / shift instructions.
// Each family has a width-suffixed arm (for [X86_64], carries an OPNAME derived by
// ${concat}) and a 64-bit arm (for [X86_64], no width suffix). One invocation
// per width group keeps generated items in their original declaration order.
// Opcodes differ per width (e.g. Add 0x01 vs Add8 0x00), so they stay per row.

macro alu_rr {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $mn:literal, $opc:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86_64] : $tmpl {
               param OPNAME: String = ${concat($mn, $osuf)};
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $mn:literal, $opc:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { $($b)* }
           } )*
    };
}

// No-REX register/register ALU forms (low subclasses). Behavior-free: they root
// no isel rule and are produced only by `canonicalize_encodings`, so the REX
// forms keep sole ownership of selection.
macro alu_rr_norex {
    ( $suf:literal, $tmpl:ident, $( ( $name:ident, $mn:literal, $opc:literal ) ),* ) => {
        $( instruction ${concat($name, $suf, "Norex")} for [X86_64] : $tmpl {
               param OPNAME: String = ${concat($mn, $suf, "_norex")};
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               behavior { }
           } )*
    };
}

macro alu_ri {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $ostem:literal, $mn:literal, $opc:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86_64] : $tmpl {
               param OPNAME: String = ${concat($ostem, $osuf)};
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $opname:literal, $mn:literal, $opc:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $opname;
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

// No-REX register/immediate forms (imm32/imm16/imm8, low subclasses). Behavior-
// free, so they root no isel rule; produced only by `canonicalize_encodings`.
macro alu_ri_norex {
    ( $tmpl:ident, $( ( $name:ident, $op:literal, $mn:literal, $opc:literal, $ext:literal ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $op;
               param MNEMONIC: String = $mn;
               param OPCODE: bits<8> = $opc;
               param EXT: bits<3> = $ext;
               behavior { }
           } )*
    };
}

// Group-1 `op r/m, imm8` (0x83) short forms. Behavior-free (canonicalize-only).
macro alu_ri8 {
    ( $tmpl:ident, $dia:ident, $( ( $name:ident, $op:literal, $mn:literal, $ext:literal ) ),* ) => {
        $( instruction $name for [$dia] : $tmpl {
               param OPNAME: String = $op;
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { }
           } )*
    };
}

macro alu_ri8_sem {
    ( $tmpl:ident, $dia:ident, $( ( $name:ident, $op:literal, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [$dia] : $tmpl {
               param OPNAME: String = $op;
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

macro shift_cl {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $ostem:literal, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86_64] : $tmpl {
               param OPNAME: String = ${concat($ostem, $osuf)};
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $opname:literal, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $opname;
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

macro shift_imm {
    ( $nsuf:literal, $osuf:literal, $tmpl:ident, $( ( $name:ident, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction ${concat($name, $nsuf)} for [X86_64] : $tmpl {
               param OPNAME: String = ${concat($mn, $osuf)};
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
    ( $tmpl:ident, $( ( $name:ident, $mn:literal, $ext:literal, { $($b:tt)* } ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { $($b)* }
           } )*
    };
}

// No-REX single-dst /digit forms (group-3 unary neg/not, by-cl shifts) over the
// low subclasses. The opcode is fixed by the template; only EXT and mnemonic
// vary. Behavior-free, so they root no isel rule (canonicalize/assembler only).
macro reg_ext_norex {
    ( $tmpl:ident, $( ( $name:ident, $op:literal, $mn:literal, $ext:literal ) ),* ) => {
        $( instruction $name for [X86_64] : $tmpl {
               param OPNAME: String = $op;
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { }
           } )*
    };
}

// No-REX shift/rotate-by-immediate forms (low subclasses). Behavior-free.
macro shift_imm_norex {
    ( $suf:literal, $tmpl:ident, $( ( $name:ident, $mn:literal, $ext:literal ) ),* ) => {
        $( instruction ${concat($name, $suf, "Norex")} for [X86_64] : $tmpl {
               param OPNAME: String = ${concat($mn, $suf, "_norex")};
               param MNEMONIC: String = $mn;
               param EXT: bits<3> = $ext;
               behavior { }
           } )*
    };
}

// Template-family macros. x86 width variants share a ModR/M scaffold but the
// encoding *shape* changes with width: REX.W is a bit param (64 vs 32/8), the
// 0x66 operand-size prefix (16-bit) shifts every offset by 8, and the 8-bit
// high-byte forms drop REX entirely. One arm per shape, each writing its offsets
// once. Templates emit no code themselves, so only the derived instructions
// matter for output. The rex! fragment is not used here: it covers only the
// plain no-prefix REX layout, while these shapes vary the REX bits' sources,
// drop the byte, or shift offsets past a prefix.

macro tmpl_rr {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => src[3],
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => src[0..2],
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => src[3],
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => OPCODE,
                24..26 => dst[0..2],
                27..29 => src[0..2],
                30..31 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
    ( $name:ident, $cls:ident, high8 ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0..7 => OPCODE,
                8..9 => dst[0..1],
                10 => 0b1,
                11..12 => src[0..1],
                13 => 0b1,
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
    // No REX prefix: opcode + ModR/M only (32/8-bit low registers).
    ( $name:ident, $cls:ident, norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0..7 => OPCODE,
                8..10 => dst[0..2],
                11..13 => src[0..2],
                14..15 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
    // 0x66 operand-size prefix, no REX (16-bit low registers).
    ( $name:ident, $cls:ident, prefix66norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            operands { dst: $cls, src: $cls, }
            encoding {
                0..7 => 0x66,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => src[0..2],
                22..23 => 0b11,
            }
            asm { "{self.MNEMONIC} {dst}, {src}" }
        }
    };
}

macro tmpl_ri {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<32>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..55 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, byte ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => 0b0,
                4..7 => 0b0100,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<16>, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => 0b0,
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => OPCODE,
                24..26 => dst[0..2],
                27..29 => EXT,
                30..31 => 0b11,
                32..47 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, high8 ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => OPCODE,
                8..9 => dst[0..1],
                10 => 0b1,
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    // No REX: opcode + ModR/M + imm32 (32-bit low registers).
    ( $name:ident, $cls:ident, norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<32>, }
            encoding {
                0..7 => OPCODE,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
                16..47 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    // 0x66 prefix, no REX + imm16 (16-bit low registers).
    ( $name:ident, $cls:ident, prefix66norex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<16>, }
            encoding {
                0..7 => 0x66,
                8..15 => OPCODE,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..39 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    // No REX + imm8 (8-bit low registers al/cl/dl/bl, opcode 0x80/0xC6).
    ( $name:ident, $cls:ident, bytenorex ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param OPCODE: bits<8>;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => OPCODE,
                8..10 => dst[0..2],
                11..13 => EXT,
                14..15 => 0b11,
                16..23 => imm,
            }
            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
}

// Group-1 `op r/m, imm8` (0x83 /digit ib): the sign-extended-imm8 short form.
// REX.W (64), plain (32), 0x66 (16), and their REX-free low-register variants.
macro tmpl_ri8 {
    ( $name:ident, $dia:ident, $cls:ident, rexw = $rexw:literal ) => {
        template $name for [$dia] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0 => dst[3],
                1 => 0b0,
                2 => 0b0,
                3 => $rexw,
                4..7 => 0b0100,
                8..15 => 0x83,
                16..18 => dst[0..2],
                19..21 => EXT,
                22..23 => 0b11,
                24..31 => imm,
