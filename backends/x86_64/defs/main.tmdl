            asm { "{self.MNEMONIC} {dst}, {imm}" }
        }
    };
    ( $name:ident, $cls:ident, prefix66 ) => {
        template $name for [X86_64] {
            param MNEMONIC: String;
            param EXT: bits<3>;
            operands { dst: $cls, imm: bits<8>, }
            encoding {
                0..7 => 0x66,
                8 => dst[3],
                9 => 0b0,
                10 => 0b0,
                11 => 0b0,
                12..15 => 0b0100,
                16..23 => 0xC1,
                24..26 => dst[0..2],
                27..29 => EXT,
                30..31 => 0b11,
                32..39 => imm,
