// RUN: not tir mc --march=x86_64 --stage=isel %s

// FINDING G4 (isel-gap): a cmpi that is NOT fused into a branch (its boolean
// result is materialized via setcc) has no materializer: "missing atomic
// materializer rule for semantic kind Lt". Only branch-fused compares lower.

module {
  func @f(%0:!i64, %1:!i64) -> !i1 {
    %2 = cmpi %0, %1 {predicate = "slt"} : !i1
    return %2
  }
  module_end
}
