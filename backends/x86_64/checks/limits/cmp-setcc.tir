// RUN: tir mc --march=x86_64 --stage=isel %s | filecheck %s

// A cmpi materialized as a value (not fused into a branch) lowers to `cmp` +
// `setcc`: the flag-definer (`cmp`) is composed with the flag-reading value
// materializer (`setl`) into an `slt`-style value rule. Works for i32 and i64
// (the `[X86]` setcc pairs with the `[X86_64]` cmp — X86 requires X86_64), and
// the boolean is matched regardless of setcc's 8-bit destination width.

module {
  func @f(%0:!i64, %1:!i64) -> !i1 {
    %2 = cmpi %0, %1 {predicate = "slt"} : !i1
    return %2
  }
  module_end
}

// CHECK: asm.symbol {name = "f"
// CHECK: x86_64.cmp
// CHECK: x86_64.setl
