// RUN: tir mc --march=x86_64 --stage=regalloc %s | filecheck %s

// SysV passes integer args past the 6th on the stack. The callee reloads them
// from the incoming stack area before use.

module {
  func @f(%0:!i64,%1:!i64,%2:!i64,%3:!i64,%4:!i64,%5:!i64,%6:!i64,%7:!i64) -> !i64 {
    %8 = addi %6, %7 : !i64
    return %8
  }
  module_end
}

// CHECK: x86_64.mov_load_disp {dst = {{r[a-z0-9]+}}, base = rsp, imm = 8}
// CHECK: x86_64.mov_load_disp {dst = {{r[a-z0-9]+}}, base = rsp, imm = 16}
