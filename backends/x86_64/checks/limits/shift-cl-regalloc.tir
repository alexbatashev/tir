// RUN: tir mc --march=x86_64 --stage=regalloc %s | filecheck %s

// Register-count shifts constrain the count at this program point to rcx. The
// argument arrives in rsi, so register allocation inserts the required copy.

module {
  func @shl(%a: !i64, %b: !i64, %c: !i64, %d: !i64) -> !i64 {
    %r = shli %a, %b : !i64
    return %r
  }
  module_end
}

// CHECK: x86_64.mov {dst = rcx
// CHECK: x86_64.shl_cl {dst = {{[a-z0-9]+}}, rcx = rcx}
