// RUN: not tir mc --march=x86_64 --filetype=obj-ascii %s

// FINDING G5 (pipeline gap, NOT a backend bug): codegen only accepts
// unstructured (CFG) control flow, so rejecting scf here is correct. The gap is
// that no scf->cf lowering pass runs in the mc pipeline, so scf.for survives
// selection verbatim and object emission fails: "cannot encode 'for' into an
// object file". Same for scf.while / scf.if. This probe marks the missing pass.

module {
  func @loop(%0: !index, %1: !index, %2: !index) {
    scf.for %0, %1, %2 {
      scf.yield
    }
    return
  }
  module_end
}
