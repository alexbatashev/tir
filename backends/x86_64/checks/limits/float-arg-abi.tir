// RUN: tir mc --march=x86_64 --stage=regalloc %s | filecheck %s

// SysV classifies f64 parameters in the XMM register file, beginning at xmm0.

module {
  func @addf(%0: !f64, %1: !f64) -> !f64 {
    %2 = addf %0, %1 : !f64
    return %2
  }
  module_end
}

// CHECK: arg_regs = [%virt0:XMM, %virt1:XMM]
// CHECK: x86_64.addsd {dst = xmm0, src = xmm1}
