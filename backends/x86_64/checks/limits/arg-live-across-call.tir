// RUN: tir mc --march=x86_64 --stage=regalloc %s

// Incoming argument registers are point constraints. The body gets a detached
// virtual copy, allowing an argument used after a call to move to a callee-saved
// register or spill instead of remaining pinned to a caller-clobbered register.

module {
  declare @g(!i64) -> !i64
  func @f(%0:!i64) -> !i64 {
    %r = call @g(%0 : !i64) -> !i64
    %res = muli %0, %r : !i64
    return %res
  }
  module_end
}
