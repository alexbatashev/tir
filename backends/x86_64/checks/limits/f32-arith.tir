// RUN: tir mc --march=x86_64 --stage=isel %s | filecheck %s

// f32 scalar arithmetic selects SSE single-precision forms.

module {
  func @f(%0:!f32, %1:!f32) -> !f32 {
    %2 = addf %0, %1 : !f32
    %3 = mulf %2, %1 : !f32
    return %3
  }
  module_end
}

// CHECK:      x86_64.addss {dst = %virt2:XMM32, dst_tied = %virt0:XMM32, src = %virt1:XMM32}
// CHECK-NEXT: x86_64.mulss {dst = %virt3:XMM32, dst_tied = %virt1:XMM32, src = %virt2:XMM32}
