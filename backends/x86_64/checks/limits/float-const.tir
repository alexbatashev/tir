// RUN: tir mc --march=x86_64 --filetype=obj-ascii %s | filecheck %s

// constantf materializes through a raw bit-pattern move into XMM.

module {
  func @f() -> !f64 {
    %0 = constantf {value = 1.5} : !f64
    return %0
  }
  module_end
}

// CHECK: [0x48, 0xB8, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xF8, 0x3F]
// CHECK: [0x66, 0x48, 0x0F, 0x6E, 0xC0]
// CHECK: [0xC3]
