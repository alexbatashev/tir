// RUN: not tir mc --march=x86_64 --filetype=obj-ascii %s

// FINDING G3 (isel-gap): float constants are never materialized; `constantf`
// survives selection and object emission fails: "cannot encode 'constantf'".

module {
  func @f() -> !f64 {
    %0 = constantf {value = 1.5} : !f64
    return %0
  }
  module_end
}
