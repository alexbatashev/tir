// RUN: not tir mc --march=x86_64 --stage=isel %s

// FINDING G2 (isel-gap): trunci has no materializer: "missing atomic
// materializer rule for semantic kind Extract". (extsi/extui do lower, but
// miscompile - see sign-zero-extend.tir.)

module {
  func @tr(%0: !i64) -> !i32 {
    %1 = trunci %0 : !i32
    return %1
  }
  module_end
}
