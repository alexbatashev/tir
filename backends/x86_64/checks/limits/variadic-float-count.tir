// RUN: tir mc --march=x86_64 --stage=regalloc %s | filecheck %s

module {
  declare @consume(!i64, !f64) -> !i64
  func @caller(%0: !i64, %1: !f64) -> !i64 {
    %2 = call @consume variadic 1(%0, %1 : !i64, !f64) -> !i64
    return %2
  }
  module_end
}

// CHECK: x86_64.mov_imm32 {{.*}}imm = 1
// CHECK-NEXT: asm.vcall {callee = "consume"
