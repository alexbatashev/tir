// RUN: tir mc --march=x86_64 --filetype=obj-ascii %s | filecheck %s

// ptr.alloca lowers to a frame slot address, so stack load/store code reaches
// object emission.

module {
  func @f(%0:!i32) -> !i32 {
    %p = ptr.alloca : !ptr.p<!i32>
    ptr.store %0, %p
    %v = ptr.load %p : !i32
    return %v
  }
  module_end
}

// CHECK: f:
