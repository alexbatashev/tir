// RUN: not tir mc --march=x86_64 --filetype=obj-ascii %s

// FINDING G6 (isel-gap): ptr.alloca is not lowered by the backend. Object
// emission fails: "cannot encode 'alloca'". Load/store through a pointer arg
// work; the JIT path only survives because it runs Mem2Reg first.

module {
  func @f(%0:!i32) -> !i32 {
    %p = ptr.alloca : !ptr.p<!i32>
    ptr.store %0, %p
    %v = ptr.load %p : !i32
    return %v
  }
  module_end
}
