// RUN: tir mc --march=x86_64 --stage=regalloc %s | filecheck %s

// SysV passes the seventh integer argument at rsp before the call. The 8-byte
// argument slot is padded to 16 bytes, and the existing 8-byte call-alignment
// adjustment makes the total reservation 24 bytes.

module {
  declare @g(!i64, !i64, !i64, !i64, !i64, !i64, !i64) -> !i64
  func @f(%0:!i64) -> !i64 {
    %r = call @g(%0, %0, %0, %0, %0, %0, %0 : !i64, !i64, !i64, !i64, !i64, !i64, !i64) -> !i64
    return %r
  }
  module_end
}

// CHECK: x86_64.mov_store_disp {base = rsp, imm = -24, src = {{.*}}}
// CHECK: x86_64.add_imm {dst = rsp, imm = -24}
// CHECK: asm.vcall {callee = "g"
// CHECK: x86_64.add_imm {dst = rsp, imm = 24}
