// RUN: tir mc --march=x86_64 --stage=regalloc %s | filecheck %s

module {
  func @make_pair(%0: !i64, %1: !i64) -> !tuple<!i64, !i64> {
    %2 = make_tuple %0, %1 : !tuple<!i64, !i64>
    return %2
  }
  module_end
}

// CHECK:      asm.symbol {{.*}}name = "make_pair"
// CHECK:      x86_64.mov {dst = rax, src = rdi}
// CHECK-NEXT: x86_64.mov {dst = rdx, src = rsi}
// CHECK-NEXT: asm.vret
