// RUN: tir mc --march=armv8 --stage=regalloc %s | filecheck %s

module {
  declare @make_quad() -> !tuple<!f64, !f64, !f64, !f64>
  func @fourth() -> !f64 {
    %0 = call @make_quad() -> !tuple<!f64, !f64, !f64, !f64>
    %1 = tuple_get %0 {index = 3} : !f64
    return %1
  }
  module_end
}

// CHECK: asm.vcall {callee = "make_quad"
// CHECK: arm64.fmov_reg64 {fd = d0, fa = d3}
// CHECK: asm.vret
