// RUN: tir mc --march=armv8 --stage=regalloc %s | filecheck %s

module {
  declare @make_pair() -> !tuple<!i64, !i64>
  func @right() -> !i64 {
    %0 = call @make_pair() -> !tuple<!i64, !i64>
    %1 = tuple_get %0 {index = 1} : !i64
    return %1
  }
  module_end
}

// CHECK: asm.vcall {callee = "make_pair"
// CHECK: arm64.orr {rd = x0, rn = x31, rm = x1}
// CHECK: asm.vret
