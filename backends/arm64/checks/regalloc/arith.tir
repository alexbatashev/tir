// RUN: tir mc --march=armv8 --stage=regalloc %s | filecheck %s

module {
  func @chain(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    %3 = subi %2, %1 : !i32
    %4 = andi %3, %0 : !i32
    %5 = ori %4, %1 : !i32
    return %5
  }
  module_end
}

// CHECK: arm64.add {rd = {{x[0-9]+}}, rn = x0, rm = x1}
// CHECK: arm64.sub
// CHECK: arm64.and
// CHECK: arm64.orr {rd = x0,
// CHECK: arm64.vret
