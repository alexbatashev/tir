// RUN: tir-mc --march=arm64 --run=isel %s | filecheck %s

// The same arithmetic/logic chain selects AArch64 instructions. Note the
// mnemonics differ from RISC-V (`orr`/`eor` rather than `or`/`xor`).

module {
  func @chain(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    %3 = subi %2, %1 : !i32
    %4 = andi %3, %0 : !i32
    %5 = ori %4, %1 : !i32
    return %5
  }
  module_end
}

// CHECK: asm.symbol {name = "chain", arg_regs = [%virt0:GPR, %virt1:GPR]}
// CHECK: arm64.add {rd = %virt2:GPR, rn = %virt0:GPR, rm = %virt1:GPR}
// CHECK: arm64.sub {rd = %virt3:GPR, rn = %virt2:GPR, rm = %virt1:GPR}
// CHECK: arm64.and {rd = %virt4:GPR, rn = %virt0:GPR, rm = %virt3:GPR}
// CHECK: arm64.orr {rd = %virt5:GPR, rn = %virt1:GPR, rm = %virt4:GPR}
// CHECK: arm64.vret
