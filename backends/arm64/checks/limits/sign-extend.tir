// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s
// XFAIL: *

// ISEL GAP: `extsi` (and `extui`) cannot be lowered. isel aborts with
//   "pass pipeline failed: failed to rewrite op OpId(0)".
// The TMDL defines sxtb/sxth/sxtw/ubfm but no rule binds the widen semantics.

module {
  func @f(%0: !i32) -> !i64 {
    %1 = extsi %0 : !i64
    return %1
  }
  module_end
}

// CHECK: arm64.sxtw
