// RUN: tir mc --march=arm64 --filetype=obj-ascii %s | filecheck %s

// ptr.alloca lowers to a frame slot address, so stack load/store code reaches
// object emission.

module {
  func @f(%0: !i64) -> !i64 {
    %p = ptr.alloca : !ptr.p<!i64>
    ptr.store %0, %p
    %v = ptr.load %p : !i64
    return %v
  }
  module_end
}

// CHECK: f:
