// RUN: tir mc --march=arm64 --filetype=obj-ascii %s | filecheck %s

// Encodable float constants materialize as scalar fmov immediates.

module {
  func @f() -> !f64 {
    %0 = constantf {value = 1.5} : !f64
    return %0
  }
  module_end
}

// CHECK: [0x00, 0x10, 0x6F, 0x1E]
// CHECK: [0xC0, 0x03, 0x5F, 0xD6]
