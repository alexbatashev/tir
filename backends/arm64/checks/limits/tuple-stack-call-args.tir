// CHECK: arm64.store_float_double {ft = %virt{{[0-9]+}}:FPR64, rn = sp, imm = -24}
// CHECK: arm64.store_float_double {ft = %virt{{[0-9]+}}:FPR64, rn = sp, imm = -16}
// CHECK: arm64.store_float_double {ft = %virt{{[0-9]+}}:FPR64, rn = sp, imm = -8}
// CHECK: arm64.sub_imm {rd = sp, rn = sp, imm = 32}
// CHECK: asm.vcall {callee = "ext"
