// RUN: tir mc --march=arm64 --stage=regalloc %s | filecheck %s

module {
  func @callee(%0: !f64, %1: !f64, %2: !f64, %3: !f64, %4: !f64, %5: !f64,
               %6: !tuple<!f64, !f64, !f64, !f64>) -> !f64 {
    %7 = tuple_get %6 {index = 0} : !f64
    %8 = tuple_get %6 {index = 1} : !f64
    %9 = tuple_get %6 {index = 2} : !f64
    %10 = tuple_get %6 {index = 3} : !f64
    %11 = addf %7, %8 : !f64
    %12 = addf %9, %10 : !f64
    %13 = addf %11, %12 : !f64
    return %13
  }
  module_end
}

// CHECK: arm64.load_float_double {ft = {{d[0-9]+}}, rn = sp, imm = 0}
// CHECK: arm64.load_float_double {ft = {{d[0-9]+}}, rn = sp, imm = 8}
// CHECK: arm64.load_float_double {ft = {{d[0-9]+}}, rn = sp, imm = 16}
// CHECK: arm64.load_float_double {ft = {{d[0-9]+}}, rn = sp, imm = 24}
// CHECK: asm.vret
