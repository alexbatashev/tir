// RUN: not tir mc --march=arm64 --stage=isel %s

// i128 is wider than the target integer register and is rejected before
// selection instead of being truncated to a single 64-bit add.

module {
  func @f(%0: !i128, %1: !i128) -> !i128 {
    %2 = addi %0, %1 : !i128
    return %2
  }
  module_end
}
