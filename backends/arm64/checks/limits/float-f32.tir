// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s

// f32 scalar arithmetic selects the single-precision FP form.

module {
  func @f(%0: !f32, %1: !f32) -> !f32 {
    %2 = addf %0, %1 : !f32
    return %2
  }
  module_end
}

// CHECK: asm.symbol {name = "f", arg_regs = [%virt0:FPR32, %virt1:FPR32]}
// CHECK: arm64.fadd_s {fd = %virt2:FPR32, fa = %virt0:FPR32, fb = %virt1:FPR32}
