// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s
// XFAIL: *

// ISEL GAP: only f64 scalar FP is selectable. f32 arithmetic aborts with
//   "invalid rule set: missing atomic materializer rule for semantic kind FAdd".

module {
  func @f(%0: !f32, %1: !f32) -> !f32 {
    %2 = addf %0, %1 : !f32
    return %2
  }
  module_end
}

// CHECK: arm64.fadd
