// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s

// Coverage: f64 arithmetic selects the scalar FP ops and float arguments land in
// the FP registers (regalloc assigns d0/d1). This PASSES today and pins the
// working float path against regressions.

module {
  func @f(%0: !f64, %1: !f64) -> !f64 {
    %2 = addf %0, %1 : !f64
    %3 = subf %2, %1 : !f64
    %4 = mulf %3, %1 : !f64
    %5 = divf %4, %1 : !f64
    return %5
  }
  func @convert(%0: !i32) -> !f64 {
    %1 = sitofp %0 : !f64
    return %1
  }
  func @convert_unsigned(%0: !i32) -> !f64 {
    %1 = uitofp %0 : !f64
    return %1
  }
  func @convert_to_signed(%0: !f64) -> !i32 {
    %1 = fptosi %0 : !i32
    return %1
  }
  func @convert_to_unsigned(%0: !f64) -> !i32 {
    %1 = fptoui %0 : !i32
    return %1
  }
  func @bits_to_double(%0: !i64) -> !f64 {
    %1 = bitcast %0 : !f64
    return %1
  }
  func @double_to_bits(%0: !f64) -> !i64 {
    %1 = bitcast %0 : !i64
    return %1
  }
  func @less(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "olt"} : !i1
    return %2
  }
  func @less_equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "ole"} : !i1
    return %2
  }
  func @greater(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "ogt"} : !i1
    return %2
  }
  func @greater_equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "oge"} : !i1
    return %2
  }
  func @equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "oeq"} : !i1
    return %2
  }
  func @not_equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "une"} : !i1
    return %2
  }
  module_end
}

// CHECK: asm.symbol {name = "f"
// CHECK: arm64.fadd {fd = %virt2:FPR64, fa = %virt0:FPR64, fb = %virt1:FPR64}
// CHECK-NEXT: arm64.fsub
// CHECK-NEXT: arm64.fmul
// CHECK-NEXT: arm64.fdiv
// CHECK-NEXT: asm.vret
// CHECK: asm.symbol {name = "convert", arg_regs = [%virt{{[0-9]+}}:GPR]}
// CHECK: arm64.scvtf_d_w {fd = %virt{{[0-9]+}}:FPR64, rn = %virt{{[0-9]+}}:GPR}
// CHECK: asm.vret
// CHECK: asm.symbol {name = "convert_unsigned", arg_regs = [%virt{{[0-9]+}}:GPR]}
// CHECK: arm64.ucvtf_d_w {fd = %virt{{[0-9]+}}:FPR64, rn = %virt{{[0-9]+}}:GPR}
// CHECK: asm.vret
// CHECK: asm.symbol {name = "convert_to_signed"
// CHECK: arm64.fcvtzs_w_d {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64}
// CHECK: asm.vret
// CHECK: asm.symbol {name = "convert_to_unsigned"
// CHECK: arm64.fcvtzu_w_d {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64}
// CHECK: asm.vret
