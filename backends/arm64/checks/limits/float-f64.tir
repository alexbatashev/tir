// CHECK: arm64.fmov_x_d {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64}
// CHECK: asm.vret
// CHECK: arm64.select_float_less_than64 {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64, fb = %virt{{[0-9]+}}:FPR64}
// CHECK: arm64.select_float_greater_equal64 {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64, fb = %virt{{[0-9]+}}:FPR64}
// CHECK: arm64.select_float_less_than64 {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64, fb = %virt{{[0-9]+}}:FPR64}
// CHECK: arm64.select_float_greater_equal64 {rd = %virt{{[0-9]+}}:GPR, fa = %virt{{[0-9]+}}:FPR64, fb = %virt{{[0-9]+}}:FPR64}
