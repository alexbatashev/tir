// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s
// XFAIL: *

// ISEL GAP: `trunci` has no materializer. isel aborts with
//   "invalid rule set: missing atomic materializer rule for semantic kind Extract".

module {
  func @f(%0: !i64) -> !i32 {
    %1 = trunci %0 : !i32
    return %1
  }
  module_end
}

// CHECK: arm64
