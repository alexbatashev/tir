// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s

// A truncation is the low-bit re-view of its operand's register (a width-n value
// is the low n bits of a register), so `trunci` selects with zero instructions
// and forwards its operand. The same target-independent rule covers all targets.

module {
  func @f(%0: !i64) -> !i32 {
    %1 = trunci %0 : !i32
    return %1
  }
  module_end
}

// CHECK: asm.symbol {name = "f"
// CHECK-NOT: ubfm
// CHECK-NOT: and
// CHECK: arm64.vret %0
