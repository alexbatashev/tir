// RUN: tir mc --march=arm64 --stage=isel %s | filecheck %s

// arm64 `mul` behavior is `extract(rn * rm, XLEN - 1, 0)` — a full-width
// identity low slice of the same-width product — which canonicalizes to the
// bare `Mul` the program emits, so integer multiply selects.

module {
  func @f(%0: !i64, %1: !i64) -> !i64 {
    %2 = muli %0, %1 : !i64
    return %2
  }
  module_end
}

// CHECK: arm64.mul {rd = %virt2:GPR, rn = %virt0:GPR, rm = %virt1:GPR}
