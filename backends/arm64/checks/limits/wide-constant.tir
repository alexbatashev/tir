// RUN: tir mc --march=arm64 --filetype=asm %s | filecheck %s

// Values wider than 16 bits start from MOVZ and fill the remaining halfwords
// with MOVK.

module {
  func @f() -> !i64 {
    %0 = constant {value = 65536} : !i64
    return %0
  }
  module_end
}

// CHECK: movz {{.*}}, 0
// CHECK: movk {{.*}}, 1, 1
