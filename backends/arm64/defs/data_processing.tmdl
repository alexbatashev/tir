// MOVI Vd.4S, #imm8 (cmode = 0000): broadcast a zero-extended 8-bit immediate
// into four 32-bit lanes. `split(vd, 4, 32)` just supplies the four-lane shape.
instruction MoveImmediateVector4S for [ARMv8A64] {
    param MNEMONIC: String = "movi";
    param OPNAME: String = "movi_v4s";
    schedule { units = [WriteIALU]; }

    operands {
        vd: VPR,
        imm: bits<8>,
    }

    encoding {
        0..4 => vd,
        5..9 => imm[0..4],
        10..11 => 0b01,
        12..15 => 0b0000,
        16..18 => imm[5..7],
        19..23 => 0b00000,
        24..28 => 0b01111,
        29 => 0b0,
        30 => 0b1,
        31 => 0b0,
    }

    asm {
        "{self.MNEMONIC} {vd}, {imm}"
    }

    behavior {
        vd = concat(map(split(vd, 4, 32), |lane| zext(imm, 32)));
    }
}

// FMOV Vd.2D, #imm8 (cmode = 1111): broadcast the VFPExpandImm binary64 value
// into both doubleword lanes (the same 8-bit float immediate as scalar `fmov`).
instruction FMoveImmediateVector2D for [ARMv8A64] {
    param MNEMONIC: String = "fmov";
    param OPNAME: String = "fmov_v2d";
    schedule { units = [WriteIALU]; }

    operands {
        vd: VPR,
        imm: bits<8>,
    }

    encoding {
        0..4 => vd,
        5..9 => imm[0..4],
        10..11 => 0b01,
        12..15 => 0b1111,
        16..18 => imm[5..7],
        19..23 => 0b00000,
        24..28 => 0b01111,
        29 => 0b1,
        30 => 0b1,
        31 => 0b0,
    }

    asm {
        "{self.MNEMONIC} {vd}, {imm}"
    }

    behavior {
        vd = concat(map(split(vd, 2, 64), |lane|
            (zext(extract(imm, 7, 7), self.XLEN) << 63)
                | ((zext(0b1, self.XLEN) - zext(extract(imm, 6, 6), self.XLEN)) << 62)
                | (((zext(0b0, self.XLEN) - zext(extract(imm, 6, 6), self.XLEN))
                    & zext(0b11111111, self.XLEN)) << 54)
                | (zext(extract(imm, 5, 4), self.XLEN) << 52)
                | (zext(extract(imm, 3, 0), self.XLEN) << 48)));
    }
}

// PC-relative addressing. The operand is the raw signed offset: bytes for
// `adr`, 4KiB pages for `adrp` (which also clears the PC's page offset).
instruction AddressPCRel for [ARMv8A64] : PCRelAddr {
    param MNEMONIC: String = "adr";
    param OP: bits<1> = 0b0;

    behavior {
        rd = PC::pc + sext(imm, self.XLEN);
    }
}

instruction AddressPCRelPage for [ARMv8A64] : PCRelAddr {
    param MNEMONIC: String = "adrp";
    param OP: bits<1> = 0b1;

    behavior {
        rd = ((PC::pc >> 12) << 12) + (sext(imm, self.XLEN) << 12);
    }
}

// Conditional set (`cset rd, <cond>`, alias of csinc with inverted condition)
// and conditional select (`csel rd, rn, rm, <cond>`). The condition is spelled
// in each instruction's asm string; COND holds the hardware-encoded code
// (already inverted for cset).

instruction ConditionalSetEq for [ARMv8A64] : CondSet {
    param MNEMONIC: String = "cset";
    param OPNAME: String = "cset_eq";
    param COND: bits<4> = 0b0001;

    asm {
        "{self.MNEMONIC} {rd}, eq"
    }

    behavior {
        rd = if PSTATE::z == zext(0b1, 1) {
            zext(0b1, self.XLEN)
        } else {
            zext(0b0, self.XLEN)
        };
    }
}

instruction ConditionalSelectEq for [ARMv8A64] : CondSelect {
    param MNEMONIC: String = "csel";
    param OPNAME: String = "csel_eq";
    param COND: bits<4> = 0b0000;

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}, eq"
    }

    behavior {
        rd = if PSTATE::z == zext(0b1, 1) {
            rn
        } else {
            rm
        };
    }
}

instruction ConditionalSetNe for [ARMv8A64] : CondSet {
    param MNEMONIC: String = "cset";
    param OPNAME: String = "cset_ne";
    param COND: bits<4> = 0b0000;

    asm {
        "{self.MNEMONIC} {rd}, ne"
    }

    behavior {
        rd = if PSTATE::z == zext(0b0, 1) {
            zext(0b1, self.XLEN)
        } else {
            zext(0b0, self.XLEN)
        };
    }
}

instruction ConditionalSelectNe for [ARMv8A64] : CondSelect {
    param MNEMONIC: String = "csel";
    param OPNAME: String = "csel_ne";
    param COND: bits<4> = 0b0001;

    asm {
