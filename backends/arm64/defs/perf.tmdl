// Cycle-approximate performance model for AArch64 (ARMv8-A).
//
// Mirrors the RISC-V model: machine-independent scheduling-class identities that
// instructions opt into via their `schedule` block, bound to concrete cost by
// each machine. The two generic cores (in-order / out-of-order) give `isasim`
// something to drive under `--timing` without claiming to model any real
// silicon.
sched_class WriteIALU { latency = 1; }
sched_class WriteLoad { latency = 3; }
sched_class WriteStore { latency = 1; }

// Generic in-order core: a single narrow pipeline, hardware-interlocked, paired
// with the in-order execution model in the Rust simulator.
machine InOrderCore ("arm64-in-order") for [ARMv8A64] {
    issue_width = 1;

    buffers {
        sb = 8;
    }

    pipeline {
        IF;
        ID;
        EX: protected;
        MEM;
        WB;
    }

    unit ALU { count = 1; }
    unit LSU { count = 1; }

    bind WriteIALU { reads = ID; writes = EX;  uses = [ALU]; }
    bind WriteLoad { reads = ID; writes = MEM; uses = [LSU]; }
    bind WriteStore { reads = ID; writes = MEM; uses = [LSU]; }

    forward ALU => ALU { latency = 0; }
    forward LSU => ALU { latency = 1; }
}

// Generic out-of-order core: wider issue with a reorder buffer and load/store
// queue. Same per-instruction latencies; the difference is structural.
machine OutOfOrderCore ("arm64-ooo") for [ARMv8A64] {
    issue_width = 4;

    buffers {
        rob = 128;
        lsq = 32;
        iq = 64;
    }

    // Physical register file for renaming: 128 GPRs behind the 32 architectural
    // names. Drives dispatch-stall modeling when the rename pool is exhausted.
    reg_file {
        GPR { count = 128; }
    }

    unit ALU { count = 4; }
    unit LSU { count = 2; }

    bind WriteIALU { latency = 1; uses = [ALU]; }
    bind WriteLoad { latency = 4; uses = [LSU]; }
    bind WriteStore { latency = 1; uses = [LSU]; }
}
