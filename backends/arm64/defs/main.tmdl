isa ARMv8A64 {
    param XLEN: Integer = 64;
    param FLAG_WIDTH: Integer = 1;
}

register_class PC for [ARMv8A64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

register_class GPR for [ARMv8A64] {
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = self.XLEN;

    registers {
        x0 => { traits = [argument, return_value, caller_saved] },
        x1..x7 => { traits = [argument, caller_saved] },
        x8..x28 => { traits = [caller_saved] },
        x29("fp") => { traits = [stack_pointer, callee_saved] },
        x30("lr") => { traits = [return_address, caller_saved] },
        x31("xzr") => { traits = [hardwired_zero] },
    }
}

register_class PSTATE for [ARMv8A64] {
    param ENCODING_LEN: Integer = 2;
    param WIDTH: Integer = self.FLAG_WIDTH;

    registers {
        n => { traits = [] },
        z => { traits = [] },
        c => { traits = [] },
        v => { traits = [] },
    }
}

// Data Processing -- Register (add/sub, shifted register)
template AddSubReg for [ARMv8A64] {
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b0;
    param SHIFT: bits<2> = 0b00;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01011,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

template CmpRegTemplate for [ARMv8A64] {
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param SHIFT: bits<2> = 0b00;

    operands {
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01011,
        29 => 0b1,
        30 => 0b1,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {rm}"
    }
}

// Data Processing -- Immediate (add/sub immediate)
template AddSubImm for [ARMv8A64] {
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b0;
    param SH: bits<1> = 0b0;

    operands {
        rd: GPR,
        rn: GPR,
        imm: bits<12>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..21 => imm,
        22 => SH,
        23..28 => 0b100010,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {imm}"
    }
}

// Data Processing -- Register (logical shifted register)
template LogicalReg for [ARMv8A64] {
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;
    param SHIFT: bits<2> = 0b00;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01010,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Data Processing -- 2 source (register shifts)
template ShiftReg for [ARMv8A64] {
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPCODE: bits<6>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => OPCODE,
        16..20 => rm,
        21..28 => 0b00110101,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Loads/Stores -- Unsigned immediate addressing
template LoadStoreImmUnsigned for [ARMv8A64] {
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPR,
        imm: bits<12>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm,
        22 => 0b1,
        23..24 => OPC,
        25 => V,
        26..29 => 0b1110,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

template BranchImm for [ARMv8A64] {
    param MNEMONIC: String;

    operands {
        imm: bits<26>,
    }

    encoding {
        0..25 => imm,
        26..31 => 0b000101,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

template BranchLinkImm for [ARMv8A64] {
    param MNEMONIC: String;

    operands {
        imm: bits<26>,
    }

    encoding {
        0..25 => imm,
        26..31 => 0b100101,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

template BranchReg for [ARMv8A64] {
    param MNEMONIC: String;
    param OPCODE: bits<4>;

    operands {
        rn: GPR,
    }

    encoding {
        0..4 => 0b00000,
        5..9 => rn,
        10..20 => 0b00000000000,
        21..24 => OPCODE,
        25..31 => 0b1101011,
    }

    asm {
        "{self.MNEMONIC} {rn}"
    }
}

template CondBranchImm for [ARMv8A64] {
    param MNEMONIC: String;
    param COND: bits<4>;

    operands {
        imm: bits<19>,
    }

    encoding {
        0..3 => COND,
        4 => 0b0,
        5..23 => imm,
        24 => 0b0,
        25..31 => 0b1010100,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}
