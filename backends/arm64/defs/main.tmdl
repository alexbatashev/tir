isa ARMv8A64 {
    param XLEN: Integer = 64;
    param FLAG_WIDTH: Integer = 1;
}

register_class PC for [ARMv8A64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

register_class GPR for [ARMv8A64] {
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = self.XLEN;

    registers {
        x0 => { traits = [argument, return_value, caller_saved] },
        x1..x7 => { traits = [argument, caller_saved] },
        x8..x28 => { traits = [caller_saved] },
        x29("fp") => { traits = [stack_pointer, callee_saved] },
        x30("lr") => { traits = [return_address, caller_saved] },
        x31("xzr") => { traits = [hardwired_zero] },
    }
}

// On AArch64 the 5-bit GPR field value 31 names the zero register (`xzr`) in most
// operand positions, but the stack pointer (`sp`) in the base register of
// addressing modes and in the `rd`/`rn` of add/sub-immediate. `GPRsp` is the same
// physical register file as `GPR` (x0..x30 are shared and alias index-for-index),
// overriding only slot 31. Operands that can reference `sp` use this class.
register_class GPRsp for [ARMv8A64] : GPR {
    registers {
        x31("sp") => { traits = [stack_pointer] },
    }
}

register_class PSTATE for [ARMv8A64] {
    param ENCODING_LEN: Integer = 2;
    param WIDTH: Integer = self.FLAG_WIDTH;

    registers {
        n => { traits = [status_flag] },
        z => { traits = [status_flag] },
        c => { traits = [status_flag] },
        v => { traits = [status_flag] },
    }
}

// Data Processing -- Register (add/sub, shifted register)
template AddSubReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b0;
    param SHIFT: bits<2> = 0b00;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01011,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

template CmpRegTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1> = 0b1;
    param SHIFT: bits<2> = 0b00;

    operands {
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01011,
        29 => 0b1,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {rm}"
    }
}

// Flag-setting compare with immediate: `subs`/`adds` with rd = xzr. The base
// register can be the stack pointer, as in add/sub (immediate).
template CmpImmTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SH: bits<1> = 0b0;

    operands {
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..21 => imm,
        22 => SH,
        23..28 => 0b100010,
        29 => 0b1,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {imm}"
    }
}

// Flag-setting logical compare: `ands` with rd = xzr.
template TstRegTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param SHIFT: bits<2> = 0b00;

    operands {
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01010,
        29..30 => 0b11,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {rm}"
    }
}

// Data Processing -- Immediate (add/sub immediate)
template AddSubImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b0;
    param SH: bits<1> = 0b0;

    // add/sub (immediate) can read and write the stack pointer.
    operands {
        rd: GPRsp,
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..21 => imm,
        22 => SH,
        23..28 => 0b100010,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {imm}"
    }
}

// Data Processing -- Register (logical shifted register). N inverts the
// shifted operand (`bic`/`orn`/`eon`).
template LogicalReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;
    param N: bits<1> = 0b0;
    param SHIFT: bits<2> = 0b00;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => N,
        22..23 => SHIFT,
        24..28 => 0b01010,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Data Processing -- 2 source (register shifts)
template ShiftReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPCODE: bits<6>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => OPCODE,
        16..20 => rm,
        21..28 => 0b11010110,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Loads/Stores -- Unsigned immediate addressing
template LoadStoreImmUnsigned for [ARMv8A64] {
    // Default for the family is a load; the store instructions override to WriteStore.
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    // The base register `rn` is the stack pointer in stack-relative addressing; the
    // transferred register `rt` uses the zero register at slot 31.
    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm,
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// As LoadStoreImmUnsigned, but the byte-offset operand is stored scaled down
// by the access size: the field holds imm[12:1], the low bits must be zero.
template LoadStoreImmUnsignedH for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<13>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm[1..12],
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// As LoadStoreImmUnsigned, but the byte-offset operand is stored scaled down
// by the access size: the field holds imm[13:2], the low bits must be zero.
template LoadStoreImmUnsignedW for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<14>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm[2..13],
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// As LoadStoreImmUnsigned, but the byte-offset operand is stored scaled down
// by the access size: the field holds imm[14:3], the low bits must be zero.
template LoadStoreImmUnsignedD for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<15>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm[3..14],
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

template BranchImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;

    operands {
        imm: bits<26>,
    }

    encoding {
        0..25 => imm,
        26..31 => 0b000101,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

template BranchLinkImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;

    operands {
        imm: bits<26>,
    }

    encoding {
        0..25 => imm,
        26..31 => 0b100101,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

template BranchReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OPCODE: bits<4>;

    operands {
        rn: GPR,
    }

    encoding {
        0..4 => 0b00000,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => 0b11111,
        21..24 => OPCODE,
        25..31 => 0b1101011,
    }

    asm {
        "{self.MNEMONIC} {rn}"
    }
}

template CondBranchImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param COND: bits<4>;

    operands {
        imm: bits<19>,
    }

    encoding {
        0..3 => COND,
        4 => 0b0,
        5..23 => imm,
        24 => 0b0,
        25..31 => 0b0101010,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

// Data Processing -- 3 source (multiply-add family)
template DataProc3Src for [ARMv8A64] {
    schedule { units = [WriteIMul]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP31: bits<3> = 0b000;
    param O0: bits<1>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
        ra: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..14 => ra,
        15 => O0,
        16..20 => rm,
        21..23 => OP31,
        24..28 => 0b11011,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}, {ra}"
    }
}

// As DataProc3Src, but the addend register is hardwired to xzr (the `mul`,
// `mneg`, `smulh` forms).
template DataProc3SrcZr for [ARMv8A64] {
    schedule { units = [WriteIMul]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP31: bits<3> = 0b000;
    param O0: bits<1>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..14 => 0b11111,
        15 => O0,
        16..20 => rm,
        21..23 => OP31,
        24..28 => 0b11011,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Bitfield instructions with fixed immr/imms (`lsr`/`asr` immediate and the
// sign-extend aliases of SBFM/UBFM). The x-form has N = 1.
template BitfieldFixed for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;
    param IMMR: bits<6> = 0b000000;
    param IMMS: bits<6>;

    operands {
        rd: GPR,
        rn: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => IMMS,
        16..21 => IMMR,
        22 => 0b1,
        23..28 => 0b100110,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}"
    }
}

// `lsr`/`asr` immediate: SBFM/UBFM with immr = shift, imms = 63. (`lsl`
// immediate is not representable: its immr/imms are both derived from the
// shift amount, which the encoding language cannot express.)
template ShiftRightImmTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;

    operands {
        rd: GPR,
        rn: GPR,
        imm: bits<6>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b111111,
        16..21 => imm,
        22 => 0b1,
        23..28 => 0b100110,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {imm}"
    }
}

// PC-relative address computation (`adr`/`adrp`). The operand is the 21-bit
// signed offset (in bytes for adr, in 4KiB pages for adrp), stored split as
// immhi:immlo.
template PCRelAddr for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OP: bits<1>;

    operands {
        rd: GPR,
        imm: bits<21>,
    }

    encoding {
        0..4 => rd,
        5..23 => imm[2..20],
        24..28 => 0b10000,
        29..30 => imm[0..1],
        31 => OP,
    }

    asm {
        "{self.MNEMONIC} {rd}, {imm}"
    }
}

// Conditional select (`csel`). COND holds the A64 condition code; each
// instruction fixes it and spells the condition in its asm string.
template CondSelect for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param COND: bits<4>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..11 => 0b00,
        12..15 => COND,
        16..20 => rm,
        21..28 => 0b11010100,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Conditional set (`cset`): csinc rd, xzr, xzr, invert(cond). COND holds the
// already-inverted condition code, as encoded in hardware.
template CondSet for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param COND: bits<4>;

    operands {
        rd: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => 0b11111,
        10..11 => 0b01,
        12..15 => COND,
        16..20 => 0b11111,
        21..28 => 0b11010100,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}"
    }
}

// Compare-and-branch on zero (`cbz`/`cbnz`). As with the other branches, the
// immediate holds the pc-relative word offset (byte delta >> 2).
template CompareBranch for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;

    operands {
        rt: GPR,
        imm: bits<19>,
    }

    encoding {
        0..4 => rt,
        5..23 => imm,
        24 => OP,
        25..30 => 0b011010,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rt}, {imm}"
    }
}

// Test-bit-and-branch (`tbz`/`tbnz`). The 6-bit bit number is stored split as
// b5:b40; the immediate holds the pc-relative word offset.
template TestBitBranch for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OP: bits<1>;

    operands {
        rt: GPR,
        bit: bits<6>,
        imm: bits<14>,
    }

    encoding {
        0..4 => rt,
        5..18 => imm,
        19..23 => bit[0..4],
        24 => OP,
        25..30 => 0b011011,
        31 => bit[5],
    }

    asm {
        "{self.MNEMONIC} {rt}, {bit}, {imm}"
    }
}

// Loads/Stores -- unscaled 9-bit signed byte offset (`ldur`/`stur` family).
template LoadStoreUnscaled for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<9>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..11 => 0b00,
        12..20 => imm,
        21 => 0b0,
        22..23 => OPC,
        24..25 => 0b00,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// Loads/Stores -- register pair, signed 7-bit scaled offset (`ldp`/`stp`,
// 64-bit, no writeback). The operand is the byte offset; the field stores it
// scaled down by 8, so only multiples of 8 in [-512, 504] are representable,
// as in hardware.
template LoadStorePair for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param L: bits<1>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rt2: GPR,
        rn: GPRsp,
        imm: bits<10>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..14 => rt2,
        15..21 => imm[3..9],
        22 => L,
        23..25 => 0b010,
        26 => V,
        27..29 => 0b101,
        30..31 => 0b10,
    }

    asm {
        "{self.MNEMONIC} {rt}, {rt2}, [{rn}, {imm}]"
    }
}
