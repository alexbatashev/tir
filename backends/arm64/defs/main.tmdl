//! AArch64 architectural registers and the AAPCS64 calling convention.

isa ARMv8A64 {
    param XLEN: Integer = 64;
    param FLAG_WIDTH: Integer = 1;
}

register_class PC for [ARMv8A64] {
    param ENCODING_LEN: Integer = 0;
    param WIDTH: Integer = self.XLEN;

    registers {
        pc => { traits = [program_counter] },
    }
}

register_class GPR for [ARMv8A64] {
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = self.XLEN;

    registers {
        x0 => {},
        x1..x7 => {},
        x8..x17 => {},
        x18 => {},
        x19..x28 => {},
        x29("fp") => {},
        x30("lr") => {},
        x31("xzr") => { traits = [hardwired_zero] },
    }
}

// On AArch64 the 5-bit GPR field value 31 names the zero register (`xzr`) in most
// operand positions, but the stack pointer (`sp`) in the base register of
// addressing modes and in the `rd`/`rn` of add/sub-immediate. `GPRsp` is the same
// physical register file as `GPR` (x0..x30 are shared and alias index-for-index),
// overriding only slot 31. Operands that can reference `sp` use this class.
register_class GPRsp for [ARMv8A64] : GPR {
    registers {
        sp => { index = 31 },
    }
}

register_class PSTATE for [ARMv8A64] {
    param ENCODING_LEN: Integer = 2;
    param WIDTH: Integer = self.FLAG_WIDTH;

    registers {
        n => { traits = [status_flag] },
        z => { traits = [status_flag] },
        c => { traits = [status_flag] },
        v => { traits = [status_flag] },
    }
}

// SIMD&FP register file (v0..v31), 128 bits. Scalar FP instructions view the
// low 64/32 bits through the `FPR64` (`d`) / `FPR32` (`s`) classes, which share
// this file index-for-index (like the RISC-V FPR32/FPR64 aliasing). The `float`
// trait keeps float and integer operands from mixing in instruction selection.
register_class VPR for [ARMv8A64] {
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = 128;

    registers {
        v0..v31 => { traits = [float] },
    }
}

register_class FPR64 for [ARMv8A64] {
    file = VPR;
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = 64;

    registers {
        d0..d31 => { traits = [float] },
    }
}

register_class FPR32 for [ARMv8A64] {
    file = VPR;
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = 32;

    registers {
        s0..s31 => { traits = [float] },
    }
}

abi AAPCS64("aapcs64") for [ARMv8A64] {
    stack { align = 16; grows = down; red_zone = 0; slot_size = 8; }
    sp = GPRsp::sp;
    ra = GPR::x30;
    fp = GPR::x29;
    args int -> [GPR::x0..GPR::x7], then stack;
    args float -> [FPR64::d0..FPR64::d7], then stack;
    args vector -> [VPR::v0..VPR::v7], then stack;
    rets int -> [GPR::x0, GPR::x1];
    rets float -> [FPR64::d0..FPR64::d3];
    rets vector -> [VPR::v0..VPR::v3];
    callee_saved = [GPR::x19..GPR::x29, VPR::v8..VPR::v15];
    reserved = [GPR::x18];
    classifier = aapcs64;
}

// FP data-processing (2 source), double precision. OPCODE selects the operation
// (fmul 0000, fadd 0010, fsub 0011, fdiv 0001); ptype = 01 (binary64).
template FPArith64 for [ARMv8A64] {
    // No dedicated FP pipe in the model yet; account it on the ALU (timing of FP
    // is not yet calibrated — functional support first).
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OPCODE: bits<4>;

    operands {
        fd: FPR64,
        fa: FPR64,
        fb: FPR64,
    }

    encoding {
        0..4 => fd,
        5..9 => fa,
        10..11 => 0b10,
        12..15 => OPCODE,
        16..20 => fb,
        21 => 0b1,
        22..23 => 0b01,
        24..28 => 0b11110,
        29 => 0b0,
        30 => 0b0,
        31 => 0b0,
    }

    asm {
        "{self.MNEMONIC} {fd}, {fa}, {fb}"
    }
}

// Data Processing -- Register (add/sub, shifted register)
template AddSubReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b0;
    param SHIFT: bits<2> = 0b00;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01011,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

template CmpRegTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1> = 0b1;
    param SHIFT: bits<2> = 0b00;

    operands {
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01011,
        29 => 0b1,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {rm}"
    }
}

// Flag-setting compare with immediate: `subs`/`adds` with rd = xzr. The base
// register can be the stack pointer, as in add/sub (immediate).
template CmpImmTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SH: bits<1> = 0b0;

    operands {
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..21 => imm,
        22 => SH,
        23..28 => 0b100010,
        29 => 0b1,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {imm}"
    }
}

// Flag-setting logical compare: `ands` with rd = xzr.
template TstRegTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param SHIFT: bits<2> = 0b00;

    operands {
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => 0b11111,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => 0b0,
        22..23 => SHIFT,
        24..28 => 0b01010,
        29..30 => 0b11,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rn}, {rm}"
    }
}

// Data Processing -- Immediate (add/sub immediate)
template AddSubImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b0;
    param SH: bits<1> = 0b0;

    // add/sub (immediate) can read and write the stack pointer.
    operands {
        rd: GPRsp,
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..21 => imm,
        22 => SH,
        23..28 => 0b100010,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {imm}"
    }
}

// Flag-setting add/sub immediate keeps SP as a valid source, but encoding 31
// in the destination names XZR rather than SP.
template AddSubImmFlags for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;
    param SETFLAGS: bits<1> = 0b1;
    param SH: bits<1> = 0b0;

    operands {
        rd: GPR,
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..21 => imm,
        22 => SH,
        23..28 => 0b100010,
        29 => SETFLAGS,
        30 => OP,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {imm}"
    }
}

// Data Processing -- Register (logical shifted register). N inverts the
// shifted operand (`bic`/`orn`/`eon`).
template LogicalReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;
    param N: bits<1> = 0b0;
    param SHIFT: bits<2> = 0b00;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => rm,
        21 => N,
        22..23 => SHIFT,
        24..28 => 0b01010,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Data Processing -- 2 source (register shifts)
template ShiftReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPCODE: bits<6>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => OPCODE,
        16..20 => rm,
        21..28 => 0b11010110,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Loads/Stores -- Unsigned immediate addressing
template LoadStoreImmUnsigned for [ARMv8A64] {
    // Default for the family is a load; the store instructions override to WriteStore.
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    // The base register `rn` is the stack pointer in stack-relative addressing; the
    // transferred register `rt` uses the zero register at slot 31.
    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<12>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm,
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// As LoadStoreImmUnsigned, but the byte-offset operand is stored scaled down
// by the access size: the field holds imm[12:1], the low bits must be zero.
template LoadStoreImmUnsignedH for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<13>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm[1..12],
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// As LoadStoreImmUnsigned, but the byte-offset operand is stored scaled down
// by the access size: the field holds imm[13:2], the low bits must be zero.
template LoadStoreImmUnsignedW for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<14>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm[2..13],
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// As LoadStoreImmUnsigned, but the byte-offset operand is stored scaled down
// by the access size: the field holds imm[14:3], the low bits must be zero.
template LoadStoreImmUnsignedD for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<15>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..21 => imm[3..14],
        22..23 => OPC,
        24..25 => 0b01,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

template LoadStoreFloatImmUnsignedD for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param OPC: bits<2>;

    operands {
        ft: FPR64,
        rn: GPRsp,
        imm: bits<15>,
    }

    encoding {
        0..4 => ft,
        5..9 => rn,
        10..21 => imm[3..14],
        22..23 => OPC,
        24..25 => 0b01,
        26 => 0b1,
        27..29 => 0b111,
        30..31 => 0b11,
    }

    asm {
        "{self.MNEMONIC} {ft}, [{rn}, {imm}]"
    }
}

template BranchImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;

    operands {
        imm: bits<26>,
    }

    encoding {
        0..25 => imm,
        26..31 => 0b000101,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

template BranchLinkImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;

    operands {
        imm: bits<26>,
    }

    encoding {
        0..25 => imm,
        26..31 => 0b100101,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

template BranchReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OPCODE: bits<4>;

    operands {
        rn: GPR,
    }

    encoding {
        0..4 => 0b00000,
        5..9 => rn,
        10..15 => 0b000000,
        16..20 => 0b11111,
        21..24 => OPCODE,
        25..31 => 0b1101011,
    }

    asm {
        "{self.MNEMONIC} {rn}"
    }
}

template CondBranchImm for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param COND: bits<4>;

    operands {
        imm: bits<19>,
    }

    encoding {
        0..3 => COND,
        4 => 0b0,
        5..23 => imm,
        24 => 0b0,
        25..31 => 0b0101010,
    }

    asm {
        "{self.MNEMONIC} {imm}"
    }
}

// Data Processing -- 3 source (multiply-add family)
template DataProc3Src for [ARMv8A64] {
    schedule { units = [WriteIMul]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP31: bits<3> = 0b000;
    param O0: bits<1>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
        ra: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..14 => ra,
        15 => O0,
        16..20 => rm,
        21..23 => OP31,
        24..28 => 0b11011,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}, {ra}"
    }
}

// As DataProc3Src, but the addend register is hardwired to xzr (the `mul`,
// `mneg`, `smulh` forms).
template DataProc3SrcZr for [ARMv8A64] {
    schedule { units = [WriteIMul]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP31: bits<3> = 0b000;
    param O0: bits<1>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..14 => 0b11111,
        15 => O0,
        16..20 => rm,
        21..23 => OP31,
        24..28 => 0b11011,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Bitfield instructions with fixed immr/imms (`lsr`/`asr` immediate and the
// sign-extend aliases of SBFM/UBFM). The x-form has N = 1.
template BitfieldFixed for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;
    param IMMR: bits<6> = 0b000000;
    param IMMS: bits<6>;

    operands {
        rd: GPR,
        rn: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => IMMS,
        16..21 => IMMR,
        22 => 0b1,
        23..28 => 0b100110,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}"
    }
}

// `lsr`/`asr` immediate: SBFM/UBFM with immr = shift, imms = 63. (`lsl`
// immediate is not representable: its immr/imms are both derived from the
// shift amount, which the encoding language cannot express.)
template ShiftRightImmTemplate for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;

    operands {
        rd: GPR,
        rn: GPR,
        imm: bits<6>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => 0b111111,
        16..21 => imm,
        22 => 0b1,
        23..28 => 0b100110,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {imm}"
    }
}

// PC-relative address computation (`adr`/`adrp`). The operand is the 21-bit
// signed offset (in bytes for adr, in 4KiB pages for adrp), stored split as
// immhi:immlo.
template PCRelAddr for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OP: bits<1>;

    operands {
        rd: GPR,
        imm: bits<21>,
    }

    encoding {
        0..4 => rd,
        5..23 => imm[2..20],
        24..28 => 0b10000,
        29..30 => imm[0..1],
        31 => OP,
    }

    asm {
        "{self.MNEMONIC} {rd}, {imm}"
    }
}

// Conditional select (`csel`). COND holds the A64 condition code; each
// instruction fixes it and spells the condition in its asm string.
template CondSelect for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param COND: bits<4>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..11 => 0b00,
        12..15 => COND,
        16..20 => rm,
        21..28 => 0b11010100,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}"
    }
}

// Conditional set (`cset`): csinc rd, xzr, xzr, invert(cond). COND holds the
// already-inverted condition code, as encoded in hardware.
template CondSet for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param COND: bits<4>;

    operands {
        rd: GPR,
    }

    encoding {
        0..4 => rd,
        5..9 => 0b11111,
        10..11 => 0b01,
        12..15 => COND,
        16..20 => 0b11111,
        21..28 => 0b11010100,
        29..30 => 0b00,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}"
    }
}

// Compare-and-branch on zero (`cbz`/`cbnz`). As with the other branches, the
// immediate holds the pc-relative word offset (byte delta >> 2).
template CompareBranch for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OP: bits<1>;

    operands {
        rt: GPR,
        imm: bits<19>,
    }

    encoding {
        0..4 => rt,
        5..23 => imm,
        24 => OP,
        25..30 => 0b011010,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rt}, {imm}"
    }
}

// Test-bit-and-branch (`tbz`/`tbnz`). The 6-bit bit number is stored split as
// b5:b40; the immediate holds the pc-relative word offset.
template TestBitBranch for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param OP: bits<1>;

    operands {
        rt: GPR,
        bit: bits<6>,
        imm: bits<14>,
    }

    encoding {
        0..4 => rt,
        5..18 => imm,
        19..23 => bit[0..4],
        24 => OP,
        25..30 => 0b011011,
        31 => bit[5],
    }

    asm {
        "{self.MNEMONIC} {rt}, {bit}, {imm}"
    }
}

// Loads/Stores -- unscaled 9-bit signed byte offset (`ldur`/`stur` family).
template LoadStoreUnscaled for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<9>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..11 => 0b00,
        12..20 => imm,
        21 => 0b0,
        22..23 => OPC,
        24..25 => 0b00,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]"
    }
}

// Loads/Stores -- register offset (`ldr`/`str Xt, [Xn, Xm{, lsl #s}]`). OPTION
// is fixed to LSL/UXTX (0b011): the index `rm` is a full 64-bit register used
// as the offset, either unscaled (S = 0) or scaled by log2(access size)
// (S = 1). The effective address is formed in each instruction's behavior, so
// this class covers the array-indexed and pointer-chase addressing that
// compiled loops emit but the immediate-offset forms cannot express.
template LoadStoreRegOffset for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param OPTION: bits<3> = 0b011;
    param S: bits<1>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        rm: GPR,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..11 => 0b10,
        12 => S,
        13..15 => OPTION,
        16..20 => rm,
        21 => 0b1,
        22..23 => OPC,
        24..25 => 0b00,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {rm}]"
    }
}

// Loads/Stores -- register pair, signed 7-bit scaled offset (`ldp`/`stp`,
// 64-bit, no writeback). The operand is the byte offset; the field stores it
// scaled down by 8, so only multiples of 8 in [-512, 504] are representable,
// as in hardware.
template LoadStorePair for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param L: bits<1>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rt2: GPR,
        rn: GPRsp,
        imm: bits<10>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..14 => rt2,
        15..21 => imm[3..9],
        22 => L,
        23..25 => 0b010,
        26 => V,
        27..29 => 0b101,
        30..31 => 0b10,
    }

    asm {
        "{self.MNEMONIC} {rt}, {rt2}, [{rn}, {imm}]"
    }
}

// Loads/Stores -- register, unscaled 9-bit signed offset with base writeback.
// Post-indexed ([11:10] = 0b01): access at the original `rn`, then rn += imm.
// The offset is byte-granular (not scaled), as in the ldur/stur family.
template LoadStorePostIndex for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<9>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..11 => 0b01,
        12..20 => imm,
        21 => 0b0,
        22..23 => OPC,
        24..25 => 0b00,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}], {imm}"
    }
}

// Pre-indexed ([11:10] = 0b11): rn += imm first, then access at the new rn.
template LoadStorePreIndex for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param SIZE: bits<2>;
    param OPC: bits<2>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rn: GPRsp,
        imm: bits<9>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..11 => 0b11,
        12..20 => imm,
        21 => 0b0,
        22..23 => OPC,
        24..25 => 0b00,
        26 => V,
        27..29 => 0b111,
        30..31 => SIZE,
    }

    asm {
        "{self.MNEMONIC} {rt}, [{rn}, {imm}]!"
    }
}

// Loads/Stores -- register pair, signed scaled offset with base writeback.
// INDEX selects the mode: 0b001 post-indexed, 0b011 pre-indexed (0b010 is the
// no-writeback offset form in `LoadStorePair`). Each instruction spells the
// exact addressing in its behavior; rn is updated by the (unscaled) byte offset.
template LoadStorePairWriteback for [ARMv8A64] {
    schedule { units = [WriteLoad]; }
    param MNEMONIC: String;
    param L: bits<1>;
    param INDEX: bits<3>;
    param V: bits<1> = 0b0;

    operands {
        rt: GPR,
        rt2: GPR,
        rn: GPRsp,
        imm: bits<10>,
    }

    encoding {
        0..4 => rt,
        5..9 => rn,
        10..14 => rt2,
        15..21 => imm[3..9],
        22 => L,
        23..25 => INDEX,
        26 => V,
        27..29 => 0b101,
        30..31 => 0b10,
    }

    asm {
        "{self.MNEMONIC} {rt}, {rt2}, [{rn}], {imm}"
    }
}

// Data Processing -- Register (logical shifted register) with a non-zero shift
// amount. Same class as `LogicalReg` but the 6-bit shift amount is an operand
// and SHIFT selects the shift type; each instruction applies it in behavior.
template LogicalShiftedReg for [ARMv8A64] {
    schedule { units = [WriteIALU]; }
    param MNEMONIC: String;
    param SF: bits<1> = 0b1;
    param OPC: bits<2>;
    param N: bits<1> = 0b0;
    param SHIFT: bits<2>;

    operands {
        rd: GPR,
        rn: GPR,
        rm: GPR,
        imm: bits<6>,
    }

    encoding {
        0..4 => rd,
        5..9 => rn,
        10..15 => imm,
        16..20 => rm,
        21 => N,
        22..23 => SHIFT,
        24..28 => 0b01010,
        29..30 => OPC,
        31 => SF,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rn}, {rm}, {imm}"
    }
}
