// RUN: not tir-mc --march=mips --run=isel %s

// An unrecognized `--march` is a hard error: target selection fails before any
// IR is parsed, so `tir-mc` exits non-zero. `not` inverts the status, so the
// test passes precisely when the tool rejects the target.

module {
  func @add(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    return %2
  }
  module_end
}
