// RUN: tir mc --march=rv64ic --filetype=asm %s | filecheck %s
// RUN: tir mc --march=rv64ic --filetype=obj-ascii %s | filecheck %s --check-prefix=ENC
// RUN: tir mc --march=rv64i --filetype=asm %s | filecheck %s --check-prefix=NOC

module {
  func @caller(%0: !i32) -> !i32 {
    %1 = call @callee(%0 : !i32) -> !i32
    return %1
  }
  module_end
}

// The post-RA compression pass narrows the register moves to c.mv and the
// return to c.jr; the call stays a 4-byte jal because its target is a
// link-time fixup and compressed ranges cannot be relaxed. `caller` is non-leaf,
// so the callee-saved register holding the return address across the call is
// preserved by the prologue/epilogue. The frame is a single 8-byte slot rounded
// up to the psABI's 16-byte alignment, so the sp adjustment compresses to
// c.addi16sp (c.addi16sp / c.sdsp / c.ldsp).
// CHECK: caller:
// CHECK-NEXT: c.addi16sp sp, -16
// CHECK-NEXT: c.sdsp x9, 0(sp)
// CHECK-NEXT: c.mv x5, x10
// CHECK-NEXT: c.mv x10, x5
// CHECK-NEXT: c.mv x9, x1
// CHECK-NEXT: jal x1, callee
// CHECK-NEXT: c.mv x1, x9
// CHECK-NEXT: c.mv x10, x10
// CHECK-NEXT: c.ldsp x9, 0(sp)
// CHECK-NEXT: c.addi16sp sp, 16
// CHECK-NEXT: c.jr x1

// ENC: [0x7D, 0x71]
// ENC-NEXT: [0x26, 0xE0]
// ENC-NEXT: [0xAA, 0x82]
// ENC-NEXT: [0x16, 0x85]
// ENC-NEXT: [0x86, 0x84]
// ENC-NEXT: [0xEF, 0x00, 0x00, 0x00]
// ENC-NEXT: [0xA6, 0x80]
// ENC-NEXT: [0x2A, 0x85]
// ENC-NEXT: [0x82, 0x64]
// ENC-NEXT: [0x41, 0x61]
// ENC-NEXT: [0x82, 0x80]

// Without C the same program keeps the full-width forms.
// NOC: caller:
// NOC-NEXT: addi x2, x2, -16
// NOC-NEXT: sd x9, 0(x2)
// NOC-NEXT: addi x5, x10, 0
// NOC: jal x1, callee
// NOC: jalr x0, 0(x1)
