// RUN: tir mc --march=rv64i --stage=isel %s | filecheck %s

// The six comparison values a `slt`/`sltu`-class target cannot root directly
// (eq/ne and le/ge/ule/uge) bridge — through proved axioms — onto the four it
// can (lt/gt/ult/ugt) plus `xor`: `eq == (a^b) <u 1`, `sge == !(a<b)`, etc.
// Branch fusion of these predicates already worked; this is value materialization.

module {
  func @eq(%0: !i64, %1: !i64) -> !i1 {
    %2 = cmpi %0, %1 {predicate = "eq"} : !i1
    return %2
  }
  func @sge(%0: !i64, %1: !i64) -> !i1 {
    %2 = cmpi %0, %1 {predicate = "sge"} : !i1
    return %2
  }
  module_end
}

// eq(a,b) == (a^b) <u 1
// CHECK: asm.symbol {name = "eq"
// CHECK: riscv.xor
// CHECK: riscv.sltiu {{.*}}imm = 1

// sge(a,b) == !(a<b)
// CHECK: asm.symbol {name = "sge"
// CHECK: riscv.slt
// CHECK: riscv.xori {{.*}}imm = 1
