// RUN: tir mc --march=rv64i --filetype=obj-ascii %s | filecheck %s

// ptr.alloca lowers to a frame slot address, so stack load/store code reaches
// object emission.

module {
  func @sum(%0: !i32) -> !i32 {
    %p = ptr.alloca {size = 4, align = 4} : !ptr.p<!i32>
    ptr.store %0, %p
    %v = ptr.load %p : !i32
    return %v
  }
  module_end
}

// CHECK: sum:
