// XFAIL: *
// RUN: tir mc --march=rv64i --filetype=asm %s | filecheck %s

// PIPELINE GAP (not a backend bug): codegen only accepts unstructured (CFG)
// control flow, so the backend rejecting scf is correct. The gap is a missing
// scf->cf lowering pass upstream of isel: scf.for passes through --stage=isel
// unchanged and asm/obj emission aborts with "cannot print 'for' as assembly".
// This probe marks the missing lowering pass.

module {
  func @a(%lo: !index, %hi: !index, %st: !index) {
    scf.for %lo, %hi, %st {
      scf.yield
    }
    return
  }
  module_end
}

// CHECK: a:
