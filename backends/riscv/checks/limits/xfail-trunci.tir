// RUN: tir mc --march=rv64i --stage=isel %s | filecheck %s

// i64 -> i32 truncation selects ADDIW with an immediate zero, preserving the low
// 32 bits in an RV64 GPR.

module {
  func @t(%0: !i64) -> !i32 {
    %1 = trunci %0 : !i32
    return %1
  }
  module_end
}

// CHECK: riscv.addiw
// CHECK-SAME: imm = 0
