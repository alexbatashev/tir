// RUN: tir mc --march=rv64i --stage=regalloc %s | filecheck %s

// RISC-V passes integer args past a7 on the stack. The callee reloads them from
// the incoming stack area before use.

module {
  func @a(%0: !i64, %1: !i64, %2: !i64, %3: !i64, %4: !i64, %5: !i64, %6: !i64, %7: !i64, %8: !i64, %9: !i64) -> !i64 {
    %r = addi %8, %9 : !i64
    return %r
  }
  module_end
}

// CHECK: riscv.ld {rd = x{{[0-9]+}}, rs1 = x2, imm = 0}
// CHECK: riscv.ld {rd = x{{[0-9]+}}, rs1 = x2, imm = 8}
