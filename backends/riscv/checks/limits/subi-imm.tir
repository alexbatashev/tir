// RUN: tir mc --march=rv64i --stage=isel %s | filecheck %s

// RISC-V has no `subi`, but `x - c == x + (-c)` (a proved axiom over a constant
// operand), and the introduced `neg(const)` folds to a constant, so `subi %x, c`
// selects as `addi %x, -c`. Register/register `sub` is unaffected (the axiom's
// constant operand does not match a register).

module {
  func @s(%0: !i64) -> !i64 {
    %1 = constant {value = 10} : !i64
    %2 = subi %0, %1 : !i64
    return %2
  }
  module_end
}

// CHECK: riscv.addi {rd = %virt2:GPR, rs1 = %virt0:GPR, imm = -10}
