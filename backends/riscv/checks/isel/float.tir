// RUN: tir mc --march=rv64ifd --stage=isel %s | filecheck %s
// RUN: tir mc --march=rv32ifd --stage=isel %s | filecheck %s
// RUN: not tir mc --march=rv64i --stage=isel %s

// Builtin float arithmetic selects the F/D instructions: f32 values live in
// FPR32 and pick the .s forms, f64 values in FPR64 and pick the .d forms,
// identically on rv32 and rv64. Without the F extension selection fails
// loudly instead of miscompiling through integer rules.

module {
  func @fp32(%0: !f32, %1: !f32) -> !f32 {
    %2 = addf %0, %1 : !f32
    %3 = subf %2, %1 : !f32
    %4 = mulf %3, %0 : !f32
    %5 = divf %4, %1 : !f32
    return %5
  }
  func @fp64(%0: !f64, %1: !f64) -> !f64 {
    %2 = addf %0, %1 : !f64
    %3 = subf %2, %1 : !f64
    %4 = mulf %3, %0 : !f64
    %5 = divf %4, %1 : !f64
    return %5
  }
  func @convert(%0: !i32) -> !f64 {
    %1 = sitofp %0 : !f64
    return %1
  }
  func @convert_unsigned(%0: !i32) -> !f64 {
    %1 = uitofp %0 : !f64
    return %1
  }
  func @convert_to_signed(%0: !f64) -> !i32 {
    %1 = fptosi %0 : !i32
    return %1
  }
  func @convert_to_unsigned(%0: !f64) -> !i32 {
    %1 = fptoui %0 : !i32
    return %1
  }
  func @less(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "olt"} : !i1
    return %2
  }
  func @less_equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "ole"} : !i1
    return %2
  }
  func @greater(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "ogt"} : !i1
    return %2
  }
  func @greater_equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "oge"} : !i1
    return %2
  }
  func @equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "oeq"} : !i1
    return %2
  }
  func @not_equal(%0: !f64, %1: !f64) -> !i1 {
    %2 = cmpf %0, %1 {predicate = "une"} : !i1
    return %2
  }
  module_end
}

// CHECK: asm.symbol {name = "fp32", arg_regs = [%virt0:FPR32, %virt1:FPR32]}
// CHECK: riscv.fadd.s {fd = %virt2:FPR32, fs1 = %virt0:FPR32, fs2 = %virt1:FPR32}
// CHECK: riscv.fsub.s {fd = %virt3:FPR32, fs1 = %virt2:FPR32, fs2 = %virt1:FPR32}
// CHECK: riscv.fmul.s {fd = %virt4:FPR32, fs1 = %virt0:FPR32, fs2 = %virt3:FPR32}
// CHECK: riscv.fdiv.s {fd = %virt5:FPR32, fs1 = %virt4:FPR32, fs2 = %virt1:FPR32}
// CHECK: asm.vret

// CHECK: asm.symbol {name = "fp64", arg_regs = [%virt{{[0-9]+}}:FPR64, %virt{{[0-9]+}}:FPR64]}
// CHECK: riscv.fadd.d {fd = %virt{{[0-9]+}}:FPR64, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
// CHECK: riscv.fsub.d
// CHECK: riscv.fmul.d
// CHECK: riscv.fdiv.d
// CHECK: asm.vret

// CHECK: asm.symbol {name = "convert", arg_regs = [%virt{{[0-9]+}}:GPR]}
// CHECK: riscv.fcvt.d.w {fd = %virt{{[0-9]+}}:FPR64, rs1 = %virt{{[0-9]+}}:GPR}
// CHECK: asm.vret
// CHECK: asm.symbol {name = "convert_unsigned", arg_regs = [%virt{{[0-9]+}}:GPR]}
// CHECK: riscv.fcvt.d.wu {fd = %virt{{[0-9]+}}:FPR64, rs1 = %virt{{[0-9]+}}:GPR}
// CHECK: asm.vret
// CHECK: asm.symbol {name = "convert_to_signed", arg_regs = [%virt{{[0-9]+}}:FPR64]}
// CHECK: riscv.fcvt.w.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64}
// CHECK: asm.vret
// CHECK: asm.symbol {name = "convert_to_unsigned"
// CHECK: riscv.fcvt.wu.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64}
// CHECK: asm.vret
// CHECK: riscv.flt.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
// CHECK: riscv.fle.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
// CHECK: riscv.flt.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
// CHECK: riscv.fle.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
// CHECK: riscv.feq.d {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
// CHECK: riscv.select_float_not_equal64 {rd = %virt{{[0-9]+}}:GPR, fs1 = %virt{{[0-9]+}}:FPR64, fs2 = %virt{{[0-9]+}}:FPR64}
