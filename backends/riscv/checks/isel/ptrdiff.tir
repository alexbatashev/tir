// RUN: tir mc --march=rv64im --stage=isel %s | filecheck %s

module {
  func @distance(%0: !ptr.p<!i32>, %1: !ptr.p<!i32>) -> !i64 {
    %2 = ptr.ptrdiff %1, %0 : !i64
    %3 = constant {value = 4} : !i64
    %4 = divsi %2, %3 : !i64
    return %4
  }
  module_end
}

// CHECK: riscv.sub
// CHECK: riscv.div
