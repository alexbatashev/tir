// RUN: tir-mc --march=riscv64 --run=isel %s | filecheck %s

// Instruction selection is nested per function, so a module with two functions
// produces two independent `asm.symbol`s.

module {
  func @a(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    return %2
  }
  func @b(%0: !i32, %1: !i32) -> !i32 {
    %2 = subi %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK: asm.symbol {name = "a"
// CHECK: riscv.addw
// CHECK: asm.symbol {name = "b"
// CHECK: riscv.subw
