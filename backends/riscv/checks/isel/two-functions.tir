// RUN: tir mc --march=rv64i --stage=isel %s | filecheck %s
// RUN: tir mc --march=rv32i --stage=isel %s | filecheck %s

module {
  func @a(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    return %2
  }
  func @b(%0: !i32, %1: !i32) -> !i32 {
    %2 = subi %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK: asm.symbol {name = "a"
// CHECK: riscv.addw
// CHECK: asm.symbol {name = "b"
// CHECK: riscv.subw
