// RUN: tir mc --march=rv32im --stage=isel %s | filecheck %s

module {
  func @mul32(%0: !i32, %1: !i32) -> !i32 {
    %2 = muli %0, %1 : !i32
    return %2
  }
  module_end
}

// RV32 has no word multiply instruction; plain mul is the 32-bit operation.
// CHECK: asm.symbol {name = "mul32", arg_regs = [%virt0:GPR, %virt1:GPR]}
// CHECK: riscv.mul {rd = %virt2:GPR, rs1 = %virt0:GPR, rs2 = %virt1:GPR}
