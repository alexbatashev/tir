// RUN: tir mc --march=rv64i --stage=isel %s | filecheck %s
// RUN: tir mc --march=rv32i --stage=isel %s | filecheck %s

module {
  func @add(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK: riscv.addw {rd = %virt2:GPR, rs1 = %virt0:GPR, rs2 = %virt1:GPR}
