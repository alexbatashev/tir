// RUN: tir mc --march=rv64i --stage=regalloc %s | filecheck %s

module {
  declare @make_pair() -> !tuple<!i64, !i64>
  func @right() -> !i64 {
    %0 = call @make_pair() -> !tuple<!i64, !i64>
    %1 = tuple_get %0 {index = 1} : !i64
    return %1
  }
  module_end
}

// CHECK: asm.vcall {callee = "make_pair"
// CHECK: riscv.addi {rd = [[RIGHT:x[0-9]+]], rs1 = x11, imm = 0}
// CHECK: riscv.addi {rd = x10, rs1 = [[RIGHT]], imm = 0}
// CHECK: asm.vret
