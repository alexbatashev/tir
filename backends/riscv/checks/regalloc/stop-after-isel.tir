// RUN: tir-mc --march=riscv64 --run=isel,regalloc --stop-after=isel %s | filecheck %s

// `--stop-after=isel` truncates the pipeline before register allocation, so the
// output still holds virtual registers - a handy way to inspect just the
// selection result even when both passes are requested.

module {
  func @add(%0: !i32, %1: !i32) -> !i32 {
    %2 = addi %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK: riscv.addw {rd = %virt2:GPR, rs1 = %virt0:GPR, rs2 = %virt1:GPR}
