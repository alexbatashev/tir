// RUN: tmdlc --action=emit-ast-json --output=- %s | filecheck %s

isa TestIsa {}

register_class GPR for [TestIsa] {
    registers { x0..x1 => {  }, }
}

abi TestAbi("test") for [TestIsa] {
    stack { align = 16; grows = down; red_zone = 0; slot_size = 8; }
    sp = GPR::x1;
    args int -> [GPR::x0], then stack;
    rets int -> [GPR::x0];
     callee_saved = [];
     reserved = [];
    classifier = mystery;
}

// CHECK: ABI 'TestAbi' has unknown classifier 'mystery'; expected riscv, aapcs64, or sysv
