// RUN: tmdlc --action=emit-rust --dialect=test --output=- %s | filecheck %s

isa TestIsa {}

register_class GPR for [TestIsa] {
    registers {
        x0 => { traits = [hardwired_zero] },
        x1 => {  },
        x2 => {  },
        x3 => {  },
    }
}

abi TestAbi("test") for [TestIsa] {
    stack {
        align = 16;
        grows = down;
        red_zone = 0;
        slot_size = 8;
        save_style = frame_slots;
    }
    sp = GPR::x2;
    args int -> [GPR::x1], then stack;
    rets int -> [GPR::x1];
     callee_saved = [GPR::x2, GPR::x3];
     reserved = [GPR::x0];
    classifier = riscv;
}

// CHECK: name: "GPR",
// CHECK: file: "GPR",
// CHECK: group_width: 1,
// CHECK: static ABIS: [tir::backend::abi::AbiInfo; 1usize]
// CHECK: name: "test",
// CHECK: sp: (RegClass::GPR.id(), 2u16),
// CHECK: kind: tir::backend::abi::ValueKind::Int,
// CHECK: regs: &[(RegClass::GPR.id(), 1u16)],
// CHECK: overflow: tir::backend::abi::Overflow::Stack,
// CHECK: classifier: tir::backend::abi::ClassifierKind::Riscv,
// CHECK: pub fn abis() -> &'static [tir::backend::abi::AbiInfo]
// CHECK: pub fn default_abi() -> &'static tir::backend::abi::AbiInfo
// CHECK: pub fn abi_by_name(name: &str) -> Option<&'static tir::backend::abi::AbiInfo>
