// Hand-written checks for the per-ISA trap-entry block: a bare `trap(cause)`
// statement inlines it (an unconditional control transfer), and a `trap`
// inside an except handler binds the exception payload to the handler's
// parameters. Do not regenerate with update_checks.py.

// RUN: tmdlc --action=emit-smtlib --dialect=trap --isa=TrapIsa --output=- %S/../Inputs/trap.tmdl | filecheck %s

// `trap(11)` with no tval argument: the missing payload reads as zero, and
// the bare trap counts as a PC write.
// CHECK: ; INSTRUCTION: tcall writes-pc=true
// CHECK: (define-fun execute_tcall ((st TMDLState)) TMDLState
// CHECK-NEXT: (write_pc (write_csr (write_csr (write_csr st (_ bv833 12) (pc st)) (_ bv834 12) ((_ zero_extend 60) (_ bv11 4))) (_ bv835 12) (_ bv0 64)) (bvshl (bvlshr (read_csr st (_ bv773 12)) ((_ zero_extend 62) (_ bv2 2))) ((_ zero_extend 62) (_ bv2 2)))))

// `trap(4, addr)` in a misaligned_load handler: cause and faulting address
// flow into the inlined sequence; the trap-path PC write stays out of the
// writes-pc metadata.
// CHECK: ; INSTRUCTION: tload writes-pc=false rd:reg:gpr:5 rs1:reg:gpr:5
// CHECK: (define-fun execute_tload ((st TMDLState) (rd (_ BitVec 5)) (rs1 (_ BitVec 5))) TMDLState
// CHECK-NEXT: (let ((exc_addr0 (read_gpr st rs1))) (ite (distinct (bvand exc_addr0 (_ bv3 64)) (_ bv0 64)) (write_pc (write_csr (write_csr (write_csr st (_ bv833 12) (pc st)) (_ bv834 12) ((_ zero_extend 61) (_ bv4 3))) (_ bv835 12) exc_addr0) (bvshl (bvlshr (read_csr st (_ bv773 12)) ((_ zero_extend 62) (_ bv2 2))) ((_ zero_extend 62) (_ bv2 2)))) (write_gpr st rd ((_ sign_extend 32) (read_mem_4 st (read_gpr st rs1)))))))
