// RUN: tmdlc --action=emit-ast --output=- %S/../Inputs/macrolib.tmdl %s | filecheck %s

isa TestIsa32 {
    param WIDTH: Integer = 32;
}

register_class GPR for [TestIsa32] {
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = self.WIDTH;
    registers {
        x0..x31("r{}") => { traits = [callee_saved] },
    }
}

template Base for [TestIsa32] {
    param MNEMONIC: String;
    param OPCODE: bits<7>;

    operands {
        rs1: GPR,
        rs2: GPR,
        rd: GPR,
    }

    encoding {
        0 => 1,
        1..5 => rs1,
        6..10 => rs2,
        11..15 => rd,
        16..31 => 0,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rs1}, {rs2}"
    }
}

alu!(Add, "add", 0b0000001)
alu!(Sub, "sub", 0b0000010)

