// RUN: tmdlc --action=emit-ast --output=- %s | filecheck %s

isa TestIsa32 {
    param WIDTH: Integer = 32;
}

register_class GPR for [TestIsa32] {
    param ENCODING_LEN: Integer = 5;
    param WIDTH: Integer = self.WIDTH;
    registers {
        x0..x31("r{}") => {                         },
    }
}

template Base for [TestIsa32] {
    param MNEMONIC: String;
    param OPCODE: bits<7>;

    operands {
        rs1: GPR,
        rs2: GPR,
        rd: GPR,
    }

    encoding {
        0 => 1,
        1..5 => rs1,
        6..10 => rs2,
        11..15 => rd,
        16..31 => 0,
    }

    asm {
        "{self.MNEMONIC} {rd}, {rs1}, {rs2}"
    }
}

macro alu {
    ($name:ident, $mn:literal, $opc:literal) => {
        instruction ${concat($name, 32)} for [TestIsa32] : Base {
            param MNEMONIC: String = $mn;
            param OPCODE: bits<7> = $opc;
            behavior { rd = rs1 + rs2; }
        }
    };
}

alu!(Add, "add", 0b0000001)
alu!(Sub, "sub", 0b0000010)

