{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TMDL checked AST",
  "description": "Versioned, checked TMDL abstract syntax tree.",
  "type": "object",
  "properties": {
    "files": {
      "description": "Checked input files in command-line order.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/File"
      }
    },
    "version": {
      "description": "JSON contract revision. Its schema is fixed to `1`.",
      "type": "integer",
      "format": "uint8",
      "const": 1,
      "maximum": 255,
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "required": [
    "version",
    "files"
  ],
  "$defs": {
    "AbiArgumentGroups": {
      "description": "Atomic ABI argument-group allocation policy.",
      "type": "object",
      "properties": {
        "register_limit": {
          "$ref": "#/$defs/Expr"
        },
        "rollback": {
          "$ref": "#/$defs/AbiGroupRollback"
        }
      },
      "additionalProperties": false
    },
    "AbiGroupRollback": {
      "description": "Register state retained after an atomic argument group moves to the stack.",
      "type": "string",
      "enum": [
        "exhaust",
        "preserve"
      ]
    },
    "AbiOverflow": {
      "description": "Destination used after a pass sequence exhausts its registers.",
      "type": "string",
      "enum": [
        "int",
        "float",
        "vector",
        "stack"
      ]
    },
    "AbiPassSequence": {
      "description": "Ordered registers used to pass one kind of ABI value.",
      "type": "object",
      "properties": {
        "overflow": {
          "$ref": "#/$defs/AbiOverflow"
        },
        "registers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AbiRegisterSequence"
          }
        },
        "value_kind": {
          "$ref": "#/$defs/AbiValueKind"
        }
      },
      "additionalProperties": false,
      "required": [
        "value_kind",
        "registers"
      ]
    },
    "AbiRegister": {
      "description": "Register identified by register class and architectural name.",
      "type": "object",
      "properties": {
        "class": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "class",
        "name"
      ]
    },
    "AbiRegisterSequence": {
      "description": "A single ABI register or an inclusive register range.",
      "type": "object",
      "properties": {
        "end": {
          "$ref": "#/$defs/AbiRegister"
        },
        "start": {
          "$ref": "#/$defs/AbiRegister"
        }
      },
      "additionalProperties": false,
      "required": [
        "start"
      ]
    },
    "AbiRole": {
      "description": "Named ABI role such as the stack pointer or return address.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "register": {
          "$ref": "#/$defs/AbiRegister"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "register"
      ]
    },
    "AbiSaveStyle": {
      "description": "Mechanism used to save callee-saved registers.",
      "type": "string",
      "enum": [
        "frame_slots",
        "push_pop"
      ]
    },
    "AbiStack": {
      "description": "ABI stack layout and save convention.",
      "type": "object",
      "properties": {
        "align": {
          "$ref": "#/$defs/Expr"
        },
        "growth": {
          "$ref": "#/$defs/AbiStackGrowth"
        },
        "red_zone": {
          "$ref": "#/$defs/Expr"
        },
        "save_style": {
          "$ref": "#/$defs/AbiSaveStyle"
        },
        "slot_size": {
          "$ref": "#/$defs/Expr"
        }
      },
      "additionalProperties": false
    },
    "AbiStackGrowth": {
      "description": "Direction in which the ABI stack grows.",
      "type": "string",
      "enum": [
        "down",
        "up"
      ]
    },
    "AbiValueKind": {
      "description": "ABI value category used for argument and result classification.",
      "type": "string",
      "enum": [
        "int",
        "float",
        "vector"
      ]
    },
    "BinOp": {
      "type": "string",
      "enum": [
        "add",
        "subtract",
        "multiply",
        "divide",
        "unsigned_divide",
        "signed_remainder",
        "unsigned_remainder",
        "equal",
        "not_equal",
        "less_than",
        "greater_than",
        "less_than_equal",
        "greater_than_equal",
        "unsigned_less_than",
        "unsigned_greater_than",
        "unsigned_less_than_equal",
        "unsigned_greater_than_equal",
        "bitwise_and",
        "bitwise_or",
        "bitwise_xor",
        "shift_left_logical",
        "shift_right_logical",
        "shift_right_arithmetic"
      ]
    },
    "BuiltinFunction": {
      "type": "string",
      "enum": [
        "clamp",
        "extract",
        "bitcast",
        "log2_ceil",
        "regnum",
        "sext",
        "zext",
        "load",
        "store",
        "load_reserved",
        "store_conditional",
        "atomic_rmw",
        "fence",
        "fence_i",
        "trap",
        "split",
        "concat",
        "map",
        "reduce",
        "zip",
        "fadd",
        "fsub",
        "fmul",
        "fdiv",
        "sitofp",
        "uitofp",
        "fptosi",
        "fptoui",
        "todo"
      ]
    },
    "EncodingArm": {
      "description": "One inclusive bit range in an instruction encoding.",
      "type": "object",
      "properties": {
        "end": {
          "description": "Highest encoded bit; omitted for a single-bit arm.",
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "start": {
          "description": "Lowest encoded bit.",
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "value": {
          "$ref": "#/$defs/Expr"
        }
      },
      "additionalProperties": false,
      "required": [
        "start",
        "value"
      ]
    },
    "ExceptClause": {
      "description": "One exception handler in a `try` expression.",
      "type": "object",
      "properties": {
        "binding": {
          "type": "string"
        },
        "body": {
          "$ref": "#/$defs/Expr"
        },
        "kind": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "kind",
        "body"
      ]
    },
    "Expr": {
      "description": "A checked TMDL expression. Numeric literal values retain their source spelling.",
      "oneOf": [
        {
          "description": "Assignment to an lvalue expression.",
          "type": "object",
          "properties": {
            "destination": {
              "$ref": "#/$defs/Expr"
            },
            "kind": {
              "type": "string",
              "const": "assign"
            },
            "value": {
              "$ref": "#/$defs/Expr"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "destination",
            "value"
          ]
        },
        {
          "description": "Binary operator application.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "binary"
            },
            "lhs": {
              "$ref": "#/$defs/Expr"
            },
            "op": {
              "$ref": "#/$defs/BinOp"
            },
            "rhs": {
              "$ref": "#/$defs/Expr"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "op",
            "lhs",
            "rhs"
          ]
        },
        {
          "description": "Unary operator application.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "unary"
            },
            "op": {
              "$ref": "#/$defs/UnOp"
            },
            "value": {
              "$ref": "#/$defs/Expr"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "op",
            "value"
          ]
        },
        {
          "description": "Ordered expression block.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "block"
            },
            "returns_last": {
              "description": "Whether the final statement supplies the block value; omitted when false.",
              "type": "boolean"
            },
            "statements": {
              "description": "Statements in source order; omitted when empty.",
              "type": "array",
              "items": {
                "$ref": "#/$defs/Expr"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "kind"
          ]
        },
        {
          "description": "Function or builtin call.",
          "type": "object",
          "properties": {
            "arguments": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Expr"
              }
            },
            "callee": {
              "$ref": "#/$defs/Expr"
            },
            "kind": {
              "type": "string",
              "const": "call"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "callee"
          ]
        },
        {
          "description": "Named member access.",
          "type": "object",
          "properties": {
            "base": {
              "$ref": "#/$defs/Expr"
            },
            "kind": {
              "type": "string",
              "const": "field"
            },
            "member": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "base",
            "member"
          ]
        },
        {
          "description": "Local or declaration identifier.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "identifier"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "Conditional expression.",
          "type": "object",
          "properties": {
            "condition": {
              "$ref": "#/$defs/Expr"
            },
            "else": {
              "$ref": "#/$defs/Expr"
            },
            "kind": {
              "type": "string",
              "const": "if"
            },
            "then": {
              "$ref": "#/$defs/Expr"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "condition",
            "then"
          ]
        },
        {
          "description": "Constant index access.",
          "type": "object",
          "properties": {
            "base": {
              "$ref": "#/$defs/Expr"
            },
            "index": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            },
            "kind": {
              "type": "string",
              "const": "index"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "base",
            "index"
          ]
        },
        {
          "description": "Qualified name split into source-order segments.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "path"
            },
            "segments": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "segments"
          ]
        },
        {
          "description": "String literal without its source quotes.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "description": "Integer or bit literal retaining radix and source digits.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "integer"
            },
            "value": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "description": "Inclusive bit slice.",
          "type": "object",
          "properties": {
            "base": {
              "$ref": "#/$defs/Expr"
            },
            "end": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            },
            "kind": {
              "type": "string",
              "const": "slice"
            },
            "start": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "base",
            "start",
            "end"
          ]
        },
        {
          "description": "Precise-trap body and its ordered exception handlers.",
          "type": "object",
          "properties": {
            "body": {
              "$ref": "#/$defs/Expr"
            },
            "handlers": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ExceptClause"
              }
            },
            "kind": {
              "type": "string",
              "const": "try"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "body",
            "handlers"
          ]
        },
        {
          "description": "Builtin function used as a call target.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "builtin"
            },
            "name": {
              "$ref": "#/$defs/BuiltinFunction"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "Anonymous function used by iterator builtins.",
          "type": "object",
          "properties": {
            "body": {
              "$ref": "#/$defs/Expr"
            },
            "kind": {
              "type": "string",
              "const": "lambda"
            },
            "parameters": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "parameters",
            "body"
          ]
        },
        {
          "description": "Parser recovery node; checked successful inputs do not normally contain it.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "invalid"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind"
          ]
        }
      ]
    },
    "File": {
      "description": "One checked input file.",
      "type": "object",
      "properties": {
        "items": {
          "description": "Top-level declarations in source order after macro expansion.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/Item"
          }
        },
        "path": {
          "description": "Input path exactly as passed to `tmdlc`.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "path",
        "items"
      ]
    },
    "Forward": {
      "description": "A resource forwarding path and its latency.",
      "type": "object",
      "properties": {
        "from": {
          "type": "string"
        },
        "latency": {
          "type": "integer",
          "format": "int64"
        },
        "to": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "latency"
      ]
    },
    "IsaRequirement": {
      "description": "Boolean composition of ISA requirements.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "isa": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "single"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "isa"
          ]
        },
        {
          "type": "object",
          "properties": {
            "isas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "const": "any"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "isas"
          ]
        },
        {
          "type": "object",
          "properties": {
            "isas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "const": "all"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "isas"
          ]
        }
      ]
    },
    "Item": {
      "description": "A checked top-level TMDL declaration.",
      "oneOf": [
        {
          "description": "An instruction-set architecture and its parameters.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "isa"
            },
            "name": {
              "type": "string"
            },
            "parameters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Parameter"
              }
            },
            "requires": {
              "$ref": "#/$defs/IsaRequirement"
            },
            "trap_handler": {
              "$ref": "#/$defs/TrapHandler"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "An ABI after ABI inheritance is resolved.",
          "type": "object",
          "properties": {
            "alias": {
              "type": "string"
            },
            "argument_groups": {
              "$ref": "#/$defs/AbiArgumentGroups"
            },
            "arguments": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AbiPassSequence"
              }
            },
            "base": {
              "type": "string"
            },
            "callee_saved": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AbiRegisterSequence"
              }
            },
            "classifier": {
              "type": "string"
            },
            "isas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "const": "abi"
            },
            "name": {
              "type": "string"
            },
            "parameters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Parameter"
              }
            },
            "reserved": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AbiRegisterSequence"
              }
            },
            "returns": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AbiPassSequence"
              }
            },
            "roles": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/AbiRole"
              }
            },
            "stack": {
              "$ref": "#/$defs/AbiStack"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "A register class after register-class inheritance is resolved.",
          "type": "object",
          "properties": {
            "base": {
              "type": "string"
            },
            "file": {
              "type": "string"
            },
            "isas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "const": "register_class"
            },
            "name": {
              "type": "string"
            },
            "parameters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Parameter"
              }
            },
            "registers": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/RegisterDef"
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "A reusable instruction template. Template inheritance remains declarative.",
          "type": "object",
          "properties": {
            "assembly": {
              "$ref": "#/$defs/Expr"
            },
            "encoding": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/EncodingArm"
              }
            },
            "isas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "const": "template"
            },
            "name": {
              "type": "string"
            },
            "operands": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Operand"
              }
            },
            "parameters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Parameter"
              }
            },
            "schedule": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "template": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "An instruction declaration. Inherited template fields are not duplicated.",
          "type": "object",
          "properties": {
            "assembly": {
              "$ref": "#/$defs/Expr"
            },
            "behavior": {
              "$ref": "#/$defs/Expr"
            },
            "encoding": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/EncodingArm"
              }
            },
            "isas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "kind": {
              "type": "string",
              "const": "instruction"
            },
            "name": {
              "type": "string"
            },
            "operands": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Operand"
              }
            },
            "parameters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Parameter"
              }
            },
            "pseudo": {
              "type": "boolean"
            },
            "schedule": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "template": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name",
            "behavior"
          ]
        },
        {
          "description": "A machine-independent scheduling class.",
          "type": "object",
          "properties": {
            "default_latency": {
              "type": "integer",
              "format": "int64"
            },
            "default_throughput": {
              "type": "integer",
              "format": "int64"
            },
            "kind": {
              "type": "string",
              "const": "sched_class"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "kind",
            "name"
          ]
        },
        {
          "description": "A concrete machine performance model.",
          "type": "object",
          "properties": {
            "alias": {
              "type": "string"
            },
            "bindings": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/UnitBind"
              }
            },
            "buffers": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/NamedCount"
              }
            },
            "forwards": {
