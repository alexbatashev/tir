// RUN: tir opt %s | filecheck %s

module {
  func @field(%0: !ptr.p<!i32>, %1: !i64) -> !ptr.p<!i8> {
    %2 = ptr.ptradd %0, %1 : !ptr.p<!i8>
    return %2
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: func @field(%{{[0-9]+}}: !ptr.p<!i32>, %{{[0-9]+}}: !i64) -> !ptr.p<!i8> {
// CHECK-NEXT: %{{[0-9]+}} = ptr.ptradd %{{[0-9]+}}, %{{[0-9]+}} : !ptr.p<!i8>
// CHECK-NEXT: return %{{[0-9]+}}
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
