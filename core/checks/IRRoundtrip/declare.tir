// RUN: tir opt %s | filecheck %s

module {
  declare @puts(!ptr.p<!i8>) -> !i32
  func @main() -> !i32 {
    %0 = constant {value = 0} : !i32
    return %0
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: declare @puts(!ptr.p<!i8>) -> !i32
// CHECK-NEXT: func @main() -> !i32 {
// CHECK-NEXT: %{{[0-9]+}} = constant {value = 0} : !i32
// CHECK-NEXT: return %{{[0-9]+}}
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
