// RUN: tir opt %s | filecheck %s

module {
  func @distance(%0: !ptr.p<!i32>, %1: !ptr.p<!i32>) -> !i64 {
    %2 = ptr.ptrdiff %1, %0 : !i64
    return %2
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: func @distance(%{{[0-9]+}}: !ptr.p<!i32>, %{{[0-9]+}}: !ptr.p<!i32>) -> !i64 {
// CHECK-NEXT: %{{[0-9]+}} = ptr.ptrdiff %{{[0-9]+}}, %{{[0-9]+}} : !i64
// CHECK-NEXT: return %{{[0-9]+}}
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
