// RUN: tir opt %s | filecheck %s

// Comments may carry non-ASCII text — em-dashes (—), «guillemets», ünïcöde —
// without corrupting the parser's byte-offset position tracking. Strings and
// identifiers after a multi-byte character must still slice correctly.

module {
  func @after_unicode(%0: !i32) -> !i32 {
    // Ещё один — комментарий.
    %1 = addi %0, %0 : !i32
    return %1
  }
  module_end
}

// CHECK: func @after_unicode
// CHECK: addi
// CHECK: return
