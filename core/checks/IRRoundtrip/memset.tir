// RUN: tir opt %s | filecheck %s

module {
  func @fill(%0: !ptr.p, %1: !i8, %2: !i64) {
    ptr.memset %0, %1, %2
    return
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: func @fill(%{{[0-9]+}}: !ptr.p, %{{[0-9]+}}: !i8, %{{[0-9]+}}: !i64) {
// CHECK-NEXT: ptr.memset %{{[0-9]+}}, %{{[0-9]+}}, %{{[0-9]+}}
// CHECK-NEXT: return
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
