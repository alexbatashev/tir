// RUN: tir opt %s | filecheck %s

module {
  func @copy(%0: !ptr.p, %1: !ptr.p, %2: !i64) {
    ptr.memcpy %0, %1, %2
    return
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: func @copy(%{{[0-9]+}}: !ptr.p, %{{[0-9]+}}: !ptr.p, %{{[0-9]+}}: !i64) {
// CHECK-NEXT: ptr.memcpy %{{[0-9]+}}, %{{[0-9]+}}, %{{[0-9]+}}
// CHECK-NEXT: return
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
