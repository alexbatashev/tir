// RUN: tir opt %s | filecheck %s

module {
  func @loop(%0: !i1) -> !i32 {
    %1 = constant {value = 0} : !i32
    %2 = scf.while iter_args(%3 = %1) -> !i32 {
      scf.condition %0, %3
    } do(%4) {
      %5 = constant {value = 1} : !i32
      %6 = addi %4, %5 : !i32
      scf.yield %6
    }
    return %2
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: func @loop(%{{[0-9]+}}: !i1) -> !i32 {
// CHECK-NEXT: %{{[0-9]+}} = constant {value = 0} : !i32
// CHECK-NEXT: %{{[0-9]+}} = scf.while iter_args(%{{[0-9]+}} = %{{[0-9]+}}) -> !i32 {
// CHECK-NEXT: scf.condition %{{[0-9]+}}, %{{[0-9]+}}
// CHECK-NEXT: }
// CHECK-NEXT: do(%{{[0-9]+}}) {
// CHECK-NEXT: %{{[0-9]+}} = constant {value = 1} : !i32
// CHECK-NEXT: %{{[0-9]+}} = addi %{{[0-9]+}}, %{{[0-9]+}} : !i32
// CHECK-NEXT: scf.yield %{{[0-9]+}}
// CHECK-NEXT: }
// CHECK-NEXT: return %{{[0-9]+}}
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
