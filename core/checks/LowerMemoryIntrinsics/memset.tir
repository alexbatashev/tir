// RUN: tir opt --pass lower-memory-intrinsics %s | filecheck %s

module {
  func @fill(%0: !ptr.p, %1: !i8, %2: !i64) {
    ptr.memset %0, %1, %2
    return
  }
  module_end
}

// CHECK: module {
// CHECK-NEXT: declare @memset(!ptr.p, !i32, !i64) -> !ptr.p
// CHECK-NEXT: func @fill(%[[DEST:[0-9]+]]: !ptr.p, %[[VALUE:[0-9]+]]: !i8, %[[SIZE:[0-9]+]]: !i64) {
// CHECK-NEXT: %[[EXTENDED:[0-9]+]] = extui %[[VALUE]] : !i32
// CHECK-NEXT: %{{[0-9]+}} = call @memset(%[[DEST]], %[[EXTENDED]], %[[SIZE]] : !ptr.p, !i32, !i64) -> !ptr.p
// CHECK-NEXT: return
// CHECK-NEXT: }
// CHECK-NEXT: module_end
// CHECK-NEXT: }
