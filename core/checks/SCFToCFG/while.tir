// RUN: tir opt --pass builtin.func(scf-to-cfg) %s | filecheck %s

module {
  func @loop(%0: !i1) {
    scf.while {
      scf.condition %0
    } do {
      scf.yield
    }
    return
  }
  module_end
}

// CHECK-NOT: scf.
// CHECK: br ^bb
// CHECK: cond_br %{{[0-9]+}}, ^bb{{[0-9]+}}, ^bb{{[0-9]+}}
// CHECK: br ^bb
// CHECK: return
