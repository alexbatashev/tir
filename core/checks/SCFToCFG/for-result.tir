// RUN: tir opt --pass builtin.func(scf-to-cfg) %s | filecheck %s

module {
  func @count(%0: !index, %1: !index, %2: !index) -> !i32 {
    %3 = constant {value = 0} : !i32
    %4 = scf.for %0, %1, %2 iter_args(%5 = %3) -> !i32 {
      %6 = constant {value = 1} : !i32
      %7 = addi %5, %6 : !i32
      scf.yield %7
    }
    return %4
  }
  module_end
}

// CHECK-NOT: scf.
// CHECK: cmpi
// CHECK: cond_br
// CHECK: addi
// CHECK: return
