// RUN: tir opt --pass instcombine %s | filecheck %s
// RUN: tir opt --pass builtin.func(instcombine) %s | filecheck %s

// Saturation chains: fold 1*4->4 first, then strength-reduce x*4->x<<2.
// The shift only becomes visible after the fold produces a power-of-two constant.

module {
  func @f(%0: !i32) -> !i32 {
    %1 = constant {value = 1} : !i32
    %2 = constant {value = 4} : !i32
    %3 = muli %1, %2 : !i32
    %4 = muli %0, %3 : !i32
    return %4
  }
  module_end
}

// CHECK-LABEL: func @f
// CHECK-NOT: muli
// CHECK: shli
