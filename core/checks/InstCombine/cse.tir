// RUN: tir opt --pass instcombine %s | filecheck %s
// RUN: tir opt --pass builtin.func(instcombine) %s | filecheck %s

// Two structurally identical ops hash-cons into one e-class, so the redundant second
// computation is eliminated.

module {
  func @cse(%x: !i32) -> !i16 {
    %0 = trunci %x : !i16
    %1 = trunci %x : !i16
    return %0
  }
  module_end
}

// CHECK-LABEL: func @cse
// CHECK: trunci
// CHECK-NOT: trunci
