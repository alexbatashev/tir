// RUN: tir opt --pass instcombine %s | filecheck %s
// RUN: tir opt --pass builtin.func(instcombine) %s | filecheck %s

module {
  func @f() -> !i32 {
    %0 = constant {value = 2} : !i32
    %1 = constant {value = 3} : !i32
    %2 = addi %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK-LABEL: func @f
// CHECK-NOT: addi
// CHECK: constant {value = 5}
