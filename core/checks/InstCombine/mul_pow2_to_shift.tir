// RUN: tir opt --pass instcombine %s | filecheck %s
// RUN: tir opt --pass builtin.func(instcombine) %s | filecheck %s

module {
  func @f(%0: !i32) -> !i32 {
    %1 = constant {value = 4} : !i32
    %2 = muli %0, %1 : !i32
    return %2
  }
  module_end
}

// CHECK-LABEL: func @f
// CHECK-NOT: muli
// CHECK: shli
